apiVersion: batch/v1
kind: Job
metadata:
  name: backtest-scanner-2year
  namespace: trading-system
spec:
  template:
    spec:
      containers:
      - name: backtest-scanner
        image: trading-bot:latest
        command: ["python", "-m", "src.services.backtest.backtest_data_scanner"]
        args:
        - "--symbols"
        - "AAPL,MSFT,GOOGL,AMZN,TSLA,NVDA,META,BRK-B,UNH,JNJ,JPM,V,PG,HD,MA,BAC,ABBV,PFE,AVGO,KO,MRK,PEP,TMO,COST,ABT"
        - "--start-date"
        - "2023-01-01"
        - "--end-date"
        - "2024-12-31"
        - "--interval"
        - "1d"
        - "--force-refresh"
        - "--parallel-workers"
        - "1"
        env:
        - name: POLYGON_API_KEY
          valueFrom:
            secretKeyRef:
              name: trading-secrets
              key: polygon-api-key
        - name: ALPHA_VANTAGE_API_KEY
          valueFrom:
            secretKeyRef:
              name: trading-secrets
              key: alpha-vantage-api-key
        - name: DATABASE_URL
          valueFrom:
            secretKeyRef:
              name: trading-secrets
              key: database-url
        - name: REDIS_URL
          valueFrom:
            secretKeyRef:
              name: trading-secrets
              key: redis-url
        resources:
          requests:
            memory: "512Mi"
            cpu: "250m"
          limits:
            memory: "1Gi"
            cpu: "500m"
      restartPolicy: Never
  backoffLimit: 3 