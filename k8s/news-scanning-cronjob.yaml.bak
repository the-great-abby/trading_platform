apiVersion: batch/v1
kind: CronJob
metadata:
  name: news-scanning-job
  namespace: trading-system
  labels:
    app: news-scanning
    component: cronjob
spec:
  schedule: "0 * * * *"  # Every hour at minute 0
  concurrencyPolicy: Forbid  # Don't run if previous job is still running
  successfulJobsHistoryLimit: 3
  failedJobsHistoryLimit: 3
  jobTemplate:
    spec:
      template:
        metadata:
          labels:
            app: news-scanning
            component: job
        spec:
          restartPolicy: OnFailure
          containers:
          - name: news-scanner
            image: trading-bot:latest
            imagePullPolicy: IfNotPresent
            command: ["python"]
            args: ["-m", "src.services.workers.news_worker", "--cron-job"]
            env:
            - name: ENVIRONMENT
              value: "production"
            - name: LOG_LEVEL
              value: "INFO"
            - name: DATABASE_URL
              valueFrom:
                secretKeyRef:
                  name: trading-secrets
                  key: database-url
            - name: REDIS_URL
              valueFrom:
                secretKeyRef:
                  name: trading-secrets
                  key: redis-url
            - name: RABBITMQ_URL
              valueFrom:
                secretKeyRef:
                  name: trading-secrets
                  key: rabbitmq-url
            - name: KAFKA_BOOTSTRAP_SERVERS
              valueFrom:
                configMapKeyRef:
                  name: trading-config
                  key: kafka-bootstrap-servers
            - name: EVENTSTORE_URL
              valueFrom:
                secretKeyRef:
                  name: trading-secrets
                  key: eventstore-url
            - name: OLLAMA_URL
              valueFrom:
                configMapKeyRef:
                  name: trading-config
                  key: ollama-url
            resources:
              requests:
                memory: "256Mi"
                cpu: "100m"
              limits:
                memory: "512Mi"
                cpu: "500m"
            volumeMounts:
            - name: config-volume
              mountPath: /app/config
              readOnly: true
          volumes:
          - name: config-volume
            configMap:
              name: news-scanning-config
---
apiVersion: v1
kind: ConfigMap
metadata:
  name: news-scanning-config
  namespace: trading-system
data:
  news-sources.yaml: |
    sources:
      - name: reuters
        url: "https://www.reuters.com"
        enabled: true
      - name: bloomberg
        url: "https://www.bloomberg.com"
        enabled: true
      - name: cnbc
        url: "https://www.cnbc.com"
        enabled: true
      - name: yahoo-finance
        url: "https://finance.yahoo.com"
        enabled: true
      - name: marketwatch
        url: "https://www.marketwatch.com"
        enabled: true
    
    symbols:
      - AAPL
      - TSLA
      - JPM
      - MSFT
      - GOOGL
      - AMZN
      - NVDA
      - META
      - BRK-B
      - JNJ
      - V
      - PG
      - UNH
      - HD
      - MA
    
    scan-interval: 3600  # 1 hour in seconds
    sentiment-threshold: 0.3
    impact-threshold: 0.5 