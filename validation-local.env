# Local Validation Framework Configuration
# Use this for testing against local filesystem instead of Kubernetes

# Database Configuration (Local)
VALIDATION_DB_HOST=localhost
VALIDATION_DB_PORT=5432
VALIDATION_DB_NAME=validation_framework
VALIDATION_DB_SSL_MODE=disable

# Discovery Configuration (Local Filesystem)
VALIDATION_DEFAULT_DIRECTORY=.
VALIDATION_PATTERNS=["*_backtest*.py", "*_simulation*.py", "*_strategy*.py"]
VALIDATION_MAX_DEPTH=3
VALIDATION_INCLUDE_SUBDIRS=true

# Execution Configuration (Local)
VALIDATION_DEFAULT_TIMEOUT=300
VALIDATION_MAX_CONCURRENT=5
VALIDATION_MEMORY_LIMIT_MB=1024
VALIDATION_CPU_LIMIT_PERCENT=80

# Validation Configuration (Local)
VALIDATION_TOLERANCE_RETURN=0.01
VALIDATION_TOLERANCE_SHARPE=0.1
VALIDATION_TOLERANCE_DRAWDOWN=0.05
VALIDATION_STRATEGIES=["exact", "tolerance", "range"]

# Logging Configuration (Local)
VALIDATION_LOG_LEVEL=INFO
VALIDATION_LOG_FORMAT=json
VALIDATION_LOG_MAX_BYTES=10485760
VALIDATION_LOG_BACKUP_COUNT=5

# API Configuration (Local)
VALIDATION_CORS_ORIGINS=["*"]
VALIDATION_CORS_METHODS=["GET", "POST", "PUT", "DELETE"]
VALIDATION_CORS_HEADERS=["*"]
VALIDATION_RATE_LIMIT_ENABLED=false
VALIDATION_REQUEST_TIMEOUT=30
VALIDATION_VALIDATION_TIMEOUT=300

# Monitoring Configuration (Local)
VALIDATION_METRICS_ENABLED=true
VALIDATION_METRICS_INTERVAL=30
VALIDATION_METRICS_RETENTION=24
VALIDATION_PROMETHEUS_ENABLED=true
VALIDATION_PROMETHEUS_PORT=8000
VALIDATION_PROMETHEUS_PATH=/metrics

# Health Check Configuration (Local)
VALIDATION_HEALTH_DB_ENABLED=false
VALIDATION_HEALTH_DISK_ENABLED=true
VALIDATION_HEALTH_DISK_THRESHOLD=90
VALIDATION_HEALTH_MEMORY_ENABLED=true
VALIDATION_HEALTH_MEMORY_THRESHOLD=85













