# Docker Operations Makefile
# Usage: make -f Makefile.docker <target>

# Colors for output
GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

# Variables
DOCKER_COMPOSE := docker-compose
DOCKER := docker

# Docker Build Operations
docker-build: ## Build Docker images
	@echo "$(GREEN)Building Docker images...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml build

docker-rebuild: ## Rebuild Docker images without cache
	@echo "$(GREEN)Rebuilding Docker images without cache...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml build --no-cache

docker-build-quick-wins: ## Build quick wins Docker images
	@echo "$(GREEN)Building quick wins Docker images...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.quick-wins.yml build

docker-rebuild-quick-wins: ## Rebuild quick wins Docker images without cache
	@echo "$(GREEN)Rebuilding quick wins Docker images without cache...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.quick-wins.yml build --no-cache

# Docker Container Management
docker-up: ## Start all Docker containers
	@echo "$(GREEN)Starting Docker containers...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml up -d

docker-down: ## Stop all Docker containers
	@echo "$(GREEN)Stopping Docker containers...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml down

docker-restart: ## Restart all Docker containers
	@echo "$(GREEN)Restarting Docker containers...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml restart

docker-logs: ## Show Docker container logs
	@echo "$(GREEN)Showing Docker container logs...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml logs -f

docker-logs-api: ## Show API service logs
	@echo "$(GREEN)Showing API service logs...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml logs -f api

docker-logs-trader: ## Show trader service logs
	@echo "$(GREEN)Showing trader service logs...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml logs -f trader

docker-logs-db: ## Show database logs
	@echo "$(GREEN)Showing database logs...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml logs -f postgres

# Docker Service Management
docker-run-api: ## Run API service
	@echo "$(GREEN)Running API service...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm api

docker-run-trader: ## Run trader service
	@echo "$(GREEN)Running trader service...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm trader

docker-run-signal-client: ## Run signal client
	@echo "$(GREEN)Running signal client...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm signal-client

docker-run-strategy-manager: ## Run strategy manager
	@echo "$(GREEN)Running strategy manager...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm strategy-manager

docker-run-news-bot: ## Run news bot
	@echo "$(GREEN)Running news bot...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm news-bot

# Docker Quick Wins
docker-up-quick-wins: ## Start quick wins containers
	@echo "$(GREEN)Starting quick wins containers...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.quick-wins.yml up -d

docker-down-quick-wins: ## Stop quick wins containers
	@echo "$(GREEN)Stopping quick wins containers...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.quick-wins.yml down

docker-logs-quick-wins: ## Show quick wins logs
	@echo "$(GREEN)Showing quick wins logs...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.quick-wins.yml logs -f

# Docker Worker Management
docker-start-workers: ## Start RabbitMQ workers
	@echo "$(GREEN)Starting RabbitMQ workers...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm worker-manager

docker-rabbitmq-status: ## Check RabbitMQ status
	@echo "$(GREEN)Checking RabbitMQ status...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml exec rabbitmq rabbitmqctl status

docker-ollama-setup: ## Setup Ollama for AI services
	@echo "$(GREEN)Setting up Ollama...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm ollama ollama pull llama2

docker-ollama-status: ## Check Ollama status
	@echo "$(GREEN)Checking Ollama status...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm ollama ollama list

# Docker Testing
docker-test-market-data: ## Test market data services
	@echo "$(GREEN)Testing market data services...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml run --rm trading-cli python test_market_data_simple.py

# Docker Cleanup
docker-clean: ## Clean up Docker resources
	@echo "$(GREEN)Cleaning up Docker resources...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.dev.yml down -v
	@$(DOCKER) system prune -f

docker-clean-images: ## Remove all Docker images
	@echo "$(GREEN)Removing all Docker images...$(NC)"
	@$(DOCKER) rmi $$($(DOCKER) images -q) --force

# Docker Registry
docker-registry-up: ## Start Docker registry
	@echo "$(GREEN)Starting Docker registry...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.registry.yml up -d

docker-registry-down: ## Stop Docker registry
	@echo "$(GREEN)Stopping Docker registry...$(NC)"
	@$(DOCKER_COMPOSE) -f docker-compose.registry.yml down

docker-pull-base-images: ## Pull and store base images in local registry
	@echo "$(GREEN)Pulling and storing base images in local registry...$(NC)"
	@./scripts/pull-base-images.sh

# Help
docker-help: ## Show this help message
	@echo "$(GREEN)Docker Operations:$(NC)"
	@grep -E '^docker-[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  $(YELLOW)%-30s$(NC) %s\n", $$1, $$2}'

.PHONY: docker-help docker-build docker-rebuild docker-build-quick-wins docker-rebuild-quick-wins docker-up docker-down docker-restart docker-logs docker-logs-api docker-logs-trader docker-logs-db docker-run-api docker-run-trader docker-run-signal-client docker-run-strategy-manager docker-run-news-bot docker-up-quick-wins docker-down-quick-wins docker-logs-quick-wins docker-start-workers docker-rabbitmq-status docker-ollama-setup docker-ollama-status docker-test-market-data docker-clean docker-clean-images docker-registry-up docker-registry-down 