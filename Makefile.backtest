backend-kube-backtest-unified-advanced-complete: ## Complete unified advanced backtest workflow
	@echo "$(GREEN)Starting complete unified advanced backtest workflow...$(NC)"
	@echo "$(YELLOW)Step 1: Rebuilding Docker image...$(NC)"
