backend-kube-backtest-unified-advanced: ## Run unified advanced backtest combining all features
	@echo "$(GREEN)🚀 Running unified advanced backtest combining all features...$(NC)"
	@kubectl delete job backtest-unified-advanced -n trading-system --ignore-not-found=true
