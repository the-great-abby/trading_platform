  ai-performance.json: |
    {
      "id": null,
      "title": "AI Performance Dashboard",
      "tags": ["ai", "llm", "performance", "trading"],
      "style": "dark",
      "timezone": "browser",
      "panels": [
        {
          "id": 1,
          "title": "AI Services Status",
          "type": "stat",
          "targets": [
            {
              "expr": "up{job=\"trading-services\", instance=~\".*llm.*\"}",
              "legendFormat": "Services Up"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "thresholds"},
              "unit": "short",
              "thresholds": {
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "yellow", "value": 1},
                  {"color": "green", "value": 3}
                ]
              }
            }
          },
          "gridPos": {"h": 8, "w": 6, "x": 0, "y": 0}
        },
        {
          "id": 2,
          "title": "LLM Request Rate",
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(llm_requests_total[5m])",
              "legendFormat": "Requests/sec"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "palette-classic"},
              "unit": "reqps"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 6, "y": 0}
        },
        {
          "id": 3,
          "title": "AI Service Health",
          "type": "table",
          "targets": [
            {
              "expr": "up{job=\"trading-services\", instance=~\".*llm.*\"}",
              "format": "table",
              "instant": true
            }
          ],
          "transformations": [
            {
              "id": "organize",
              "options": {
                "excludeByName": {
                  "Time": true,
                  "__name__": true
                },
                "indexByName": {},
                "renameByName": {
                  "job": "Service",
                  "instance": "Instance",
                  "Value": "Status"
                }
              }
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "thresholds"},
              "thresholds": {
                "steps": [
                  {"color": "red", "value": null},
                  {"color": "green", "value": 1}
                ]
              }
            }
          },
          "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
        },
        {
          "id": 4,
          "title": "LLM Response Time",
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(llm_response_time_seconds_sum[5m]) / rate(llm_response_time_seconds_count[5m])",
              "legendFormat": "Response Time"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "thresholds"},
              "unit": "s",
              "thresholds": {
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 2},
                  {"color": "red", "value": 5}
                ]
              }
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16}
        },
        {
          "id": 5,
          "title": "AI Model Usage",
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(llm_model_requests_total[5m])",
              "legendFormat": "{{model}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "palette-classic"},
              "unit": "reqps"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16}
        },
        {
          "id": 6,
          "title": "Token Usage",
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(llm_tokens_used_total[5m])",
              "legendFormat": "Tokens/sec"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "palette-classic"},
              "unit": "short"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}
        },
        {
          "id": 7,
          "title": "AI Error Rate",
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(llm_errors_total[5m])",
              "legendFormat": "Errors/sec"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "thresholds"},
              "unit": "reqps",
              "thresholds": {
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "red", "value": 0.1}
                ]
              }
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}
        },
        {
          "id": 8,
          "title": "AI Processing Queue",
          "type": "timeseries",
          "targets": [
            {
              "expr": "llm_queue_length",
              "legendFormat": "Queue Length"
            }
