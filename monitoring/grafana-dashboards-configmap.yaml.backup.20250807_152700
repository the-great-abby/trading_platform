          },
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}
        },
        {
          "id": 9,
          "title": "AI Cost Tracking",
          "type": "timeseries",
          "targets": [
            {
              "expr": "rate(llm_cost_total[5m])",
              "legendFormat": "Cost/sec"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "palette-classic"},
              "unit": "currencyUSD"
            }
          },
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}
        },
        {
          "id": 10,
          "title": "AI Service Summary",
          "type": "piechart",
          "targets": [
            {
              "expr": "up{job=\"trading-services\", instance=~\".*llm.*\"}",
              "legendFormat": "{{instance}}"
            }
          ],
          "fieldConfig": {
            "defaults": {
              "color": {"mode": "palette-classic"}
