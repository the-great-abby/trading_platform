	@echo "=============================="
	@echo ""
	@echo "📊 Dashboards:"
	@echo "  Central Hub:        http://localhost:11080/"
	@echo "  Performance:        http://localhost:11000/dashboard"
	@echo "  Health:            http://localhost:11002/dashboard"
	@echo "  RSS Dashboard:     http://localhost:11003/"
	@echo "  Unified Analytics: http://localhost:11115/"
	@echo "  Unified Trading:   http://localhost:11114/"
	@echo "  Unified News:      http://localhost:11113/"
	@echo "  AI Stock:          http://localhost:11086/"
	@echo ""
	@echo "💼 Trading Services:"
	@echo "  Trading Ultra:     http://localhost:11099/"
	@echo "  Market Data:       http://localhost:11084/"
	@echo "  Backtest API:      http://localhost:11101/"
	@echo ""
	@echo "📈 Monitoring:"
	@echo "  Grafana:           http://localhost:11102/"
	@echo "  Prometheus:        http://localhost:11190/"
	@echo ""
	@echo "🤖 AI/ML Services:"
	@echo "  Ollama:            http://localhost:11120/"
	@echo "  LLM Proxy:         http://localhost:11121/"
	@echo "  Analytics:         http://localhost:11122/"
	@echo ""
	@echo "🗄️ Databases:"
	@echo "  TimescaleDB:       localhost:11140"
	@echo "  PostgreSQL:        localhost:11141"
