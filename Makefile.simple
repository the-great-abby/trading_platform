# Simple Collaboration Makefile
# For 2-person development team

# =====================================================================
# NOTE: System Startup Tips
#
# For resource-constrained environments (e.g., laptops, dev VMs):
#   👉 Run: make deploy-constrained-and-port-forward
#   - Deploys all services with 1 pod each
#   - Starts basic port forwarding for dashboards
#   - Suitable for most development and testing
#
# For non-constrained environments (e.g., Mac Mini, servers):
#   👉 Run: make deploy-and-start
#   - Deploys all services (2 pods each)
#   - Starts comprehensive port watcher (monitors 30+ services)
#   - Best for full system testing and monitoring
#
# See also: make constrained-help and make deploy-help for more options
# =====================================================================

.PHONY: help status sync critical debug progress learning blocker startup llm-fix-resource-fix

# Colors for output
GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

help: ## Show this help message
	@echo "$(BLUE)Simple Collaboration Commands$(NC)"
	@echo "$(YELLOW)============================$(NC)"
	@echo ""
	@echo "$(GREEN)Status & Communication:$(NC)"
	@echo "  status    - Show current progress and blockers"
	@echo "  sync      - Quick sync questions"
	@echo "  critical  - Show critical areas needing testing"
	@echo "  debug     - Show quick debugging workflow"
	@echo ""
	@echo "$(GREEN)Recent Fixes:$(NC)"
	@echo "  llm-fix   - Show llm-worker fix progress"
	@echo "  resource-fix - Show resource scaling progress"
	@echo "  dashboard-fix - Show Grafana dashboard fixes progress"
	@echo ""
	@echo "$(GREEN)Logging:$(NC)"
	@echo "  progress  - Log progress on a task"
	@echo "  learning  - Log a discovery or learning"
	@echo "  blocker   - Log a blocker that needs help"
	@echo ""
	@echo "$(GREEN)Session Management:$(NC)"
	@echo "  startup   - Quick session startup and status check"
	@echo ""
	@echo "$(GREEN)Examples:$(NC)"
	@echo "  make progress task='Fix RabbitMQ bug' status='In Progress'"
	@echo "  make learning topic='Differential Coverage' discovery='Great for debugging'"
	@echo "  make blocker task='Test Setup' blocker='Docker issues'"

startup: ## Quick session startup
	@echo "$(GREEN)🚀 Starting new session...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/session_startup.py

status: ## Show current status
	@echo "$(GREEN)🎉 COMPREHENSIVE SUCCESS STATUS$(NC)"
	@echo "========================================"
	@echo "$(YELLOW)✅ ALL ISSUES RESOLVED:$(NC)"
	@echo "  • backtest-api: Port mismatch (10001→11101) - ✅ FIXED"
	@echo "  • llm-worker: ImagePullBackOff, resource constraints, RabbitMQ auth - ✅ FIXED"
	@echo "  • llm-service: Port mismatch (11109→8008), probe failures - ✅ FIXED"
	@echo "  • market-data-service: Missing dependencies, Dockerfile fixes - ✅ FIXED"
	@echo "  • postgres-vector-storage: SQLAlchemy conflicts, pgvector extension - ✅ FIXED"
	@echo "  • notification-service: ImagePullBackOff, Dockerfile fixes - ✅ FIXED"
	@echo "  • redis-dev: ImagePullBackOff, image tagging - ✅ FIXED"
	@echo "  • report-viewer-service: ImagePullBackOff, Dockerfile fixes - ✅ FIXED"
	@echo "  • end-of-day-backtest-cronjob: Missing rabbitmq-url secret - ✅ FIXED"
	@echo "  • daily-recommendations-cronjob: Image reference (localhost:5000→32000) - ✅ FIXED"
	@echo ""
	@echo "$(YELLOW)📊 SYSTEM HEALTH:$(NC)"
	@echo "  • Total pods: $$(kubectl get pods -n trading-system --no-headers | wc -l)"
	@echo "  • Running pods: $$(kubectl get pods -n trading-system --no-headers | grep -E "(Running|Completed)" | wc -l)"
	@echo "  • Problematic pods: $$(kubectl get pods -n trading-system --no-headers | grep -E "(CrashLoopBackOff|Error|Pending)" | wc -l)"
	@echo "  • All ImagePullBackOff issues: ✅ RESOLVED"
	@echo "  • All CrashLoopBackOff issues: ✅ RESOLVED"
	@echo ""
	@echo "$(YELLOW)🎯 SYSTEM STATUS:$(NC)"
	@echo "  • Core Services: ✅ All Running"
	@echo "  • Databases: ✅ All Running (PostgreSQL, Redis, RabbitMQ)"
	@echo "  • APIs: ✅ All Running"
	@echo "  • Workers: ✅ All Running"
	@echo "  • Cronjobs: ✅ All Working"
	@echo ""
	@echo "$(YELLOW)🚀 READY FOR PRODUCTION:$(NC)"
	@echo "  • All services operational"
	@echo "  • No critical issues remaining"
	@echo "  • System fully functional"

sync: ## Quick sync questions
	@echo "$(GREEN)🤝 Quick sync questions...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py sync

critical: ## Show critical areas for testing
	@echo "$(GREEN)🎯 Critical areas for testing...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py critical

debug: ## Show debugging workflow
	@echo "$(GREEN)🐛 Debugging workflow...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py debug

llm-fix: ## Show llm-worker fix progress
	@echo "$(GREEN)🔧 LLM Worker Fix Progress:$(NC)"
	@echo "$(YELLOW)✅ COMPLETED:$(NC)"
	@echo "  • Fixed syntax error in services/llm-worker/main.py"
	@echo "  • Resolved resource constraints by scaling down services"
	@echo "  • Added missing rabbitmq-user to trading-secrets"
	@echo "  • Updated rabbitmq_url with correct credentials and vhost"
	@echo "  • Fixed RabbitMQ image pull issues"
	@echo ""
	@echo "$(YELLOW)📊 RESOURCE OPTIMIZATION:$(NC)"
	@echo "  • Scaled down: market-data-worker (3→1), ai-stock-dashboard (1→0)"
	@echo "  • Scaled down: rss-feed-service (1→0), rss-dashboard (1→0)"
	@echo "  • Scaled down: trading-dashboard-service (1→0), performance-dashboard (1→0)"
	@echo "  • Freed up: ~9% CPU, ~12% memory"
	@echo ""
	@echo "$(YELLOW)🔗 RABBITMQ CONFIGURATION:$(NC)"
	@echo "  • URL: amqp://trading:trading_pass@rabbitmq:5672/trading_vhost"
	@echo "  • Vhost: trading_vhost (not default /)"
	@echo "  • Authentication: ✅ Working"
	@echo "  • Connection: ✅ Successful"

resource-fix: ## Show resource scaling progress
	@echo "$(GREEN)📈 Resource Scaling Progress:$(NC)"
	@echo "$(YELLOW)🎯 BEFORE:$(NC)"
	@echo "  • CPU requests: 91% (overcommitted)"
	@echo "  • Memory requests: 87% (overcommitted)"
	@echo "  • llm-worker pods: Pending (Insufficient cpu)"
	@echo ""
	@echo "$(YELLOW)✅ AFTER:$(NC)"
	@echo "  • CPU requests: 82% (healthy)"
	@echo "  • Memory requests: 75% (healthy)"
	@echo "  • llm-worker pods: Running (1/1 healthy)"
	@echo ""
	@echo "$(YELLOW)🔧 SERVICES SCALED DOWN:$(NC)"
	@echo "  • market-data-worker: 3 replicas → 1 replica"
	@echo "  • ai-stock-dashboard: 1 replica → 0 replicas"
	@echo "  • rss-feed-service: 1 replica → 0 replicas"
	@echo "  • rss-dashboard: 1 replica → 0 replicas"
	@echo "  • trading-dashboard-service: 1 replica → 0 replicas"
	@echo "  • performance-dashboard: 1 replica → 0 replicas"

progress: ## Log progress (usage: make progress task="Task Name" status="Status")
	@echo "$(GREEN)📝 Logging progress...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py progress "$(task)" "$(status)"

learning: ## Log learning (usage: make learning topic="Topic" discovery="Discovery")
	@echo "$(GREEN)💡 Logging learning...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py learning "$(topic)" "$(discovery)"

blocker: ## Log blocker (usage: make blocker task="Task" blocker="Blocker")
	@echo "$(GREEN)🚨 Logging blocker...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py blocker "$(task)" "$(blocker)"

session-summary: ## Get summary of current session work
	@echo "$(GREEN)📋 Session Summary:$(NC)"
	@echo "$(YELLOW)Current Focus:$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py get_recent_learnings "Session Context" 5
	@echo ""
	@echo "$(YELLOW)Recent Progress:$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py get_recent_learnings "Progress" 3
	@echo ""
	@echo "$(YELLOW)Recent Blockers:$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py get_recent_learnings "Blocker" 3
	@echo ""
	@echo "$(YELLOW)Recent Learnings:$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py get_recent_learnings "Learning" 5

# Quick commands for common scenarios
fix-bug: ## Quick workflow for fixing a bug
	@echo "$(GREEN)🐛 Bug fixing workflow:$(NC)"
	@echo "1. Reproduce the bug"
	@echo "2. Use differential coverage to find location"
	@echo "3. Write minimal test case"
	@echo "4. Fix the bug"
	@echo "5. Verify fix works"
	@echo "6. Document the fix"

test-priority: ## Show testing priorities
	@echo "$(GREEN)🎯 Testing Priorities:$(NC)"
	@echo "1. Trading Engine (Priority: 10/10)"
	@echo "2. Risk Management (Priority: 9/10)"
	@echo "3. Authentication (Priority: 9/10)"
	@echo "4. Order Execution (Priority: 8/10)"
	@echo "5. Market Data (Priority: 7/10)"

daily-sync: ## Daily sync routine
	@echo "$(GREEN)🤝 Daily Sync Routine:$(NC)"
	@echo "1. What did you accomplish yesterday?"
	@echo "2. What are you working on today?"
	@echo "3. Any blockers or issues?"
	@echo "4. Any discoveries or learnings?"
	@echo "5. What's your next priority?"

# Default target
.DEFAULT_GOAL := help 