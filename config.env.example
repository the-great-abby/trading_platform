# API Keys - Choose your provider
# For Alpaca:
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# For Public API:
PUBLIC_API_KEY=your_public_api_key_here
PUBLIC_API_SECRET=your_public_api_secret_here
PUBLIC_BASE_URL=https://api.public.com
PUBLIC_USERNAME=your_public_username
PUBLIC_PASSWORD=your_public_password

# Database Configuration
DATABASE_URL=sqlite:///algo_trader.db

# Trading Configuration
INITIAL_CAPITAL=10000
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENTAGE=0.02
TAKE_PROFIT_PERCENTAGE=0.05
TRADING_INTERVAL=60

# Risk Management
MAX_DAILY_LOSS=0.05
MAX_POSITIONS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trader.log

# Data Configuration
DATA_PROVIDER=public  # Options: public, alpaca, yfinance
HISTORICAL_DAYS=30 