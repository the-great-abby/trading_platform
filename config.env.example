# API Keys - Choose your provider
# For Alpaca:
ALPACA_API_KEY=your_alpaca_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# For Public API:
PUBLIC_API_KEY=your_public_api_key_here
PUBLIC_API_SECRET=your_public_api_secret_here
PUBLIC_BASE_URL=https://api.public.com
PUBLIC_USERNAME=your_public_username
PUBLIC_PASSWORD=your_public_password

# Database Configuration
DATABASE_URL=sqlite:///algo_trader.db

# Trading Configuration
INITIAL_CAPITAL=10000
MAX_POSITION_SIZE=0.1
STOP_LOSS_PERCENTAGE=0.02
TAKE_PROFIT_PERCENTAGE=0.05
TRADING_INTERVAL=60

# Risk Management
MAX_DAILY_LOSS=0.05
MAX_POSITIONS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trader.log

# Data Configuration
DATA_PROVIDER=public  # Options: public, alpaca, yfinance
HISTORICAL_DAYS=30

# AI/LLM Configuration
OLLAMA_URL=http://10.11.135.50:11434
OLLAMA_MODEL=smollm2

# Kubernetes Secrets Management
# These variables will be managed via Makefile targets
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit the .env file to version control

# API Keys (for trading data providers)
# These will be stored as individual secrets: polygon-api-key, alpha-vantage-api-key
POLYGON_API_KEY=your_polygon_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Database Credentials
# These will be combined into a single secret: db-credentials
DB_HOST=your_database_host
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=trading_system

# Optional: Additional API keys
# TWILIO_API_KEY=your_twilio_key_here
# SENDGRID_API_KEY=your_sendgrid_key_here

# Optional: Additional database settings
# DB_PORT=5432
# DB_SSL_MODE=require 