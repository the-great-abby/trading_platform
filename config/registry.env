# Registry Configuration
# External registry URL (for building/pushing from host)
REGISTRY_EXTERNAL=localhost:32000

# Internal registry URL (for Kubernetes cluster access)
REGISTRY_INTERNAL=localhost:32000

# Registry service name
REGISTRY_SERVICE=registry

# Registry namespace
REGISTRY_NAMESPACE=default

# Registry NodePort
REGISTRY_NODEPORT=32000

# Registry internal port
REGISTRY_INTERNAL_PORT=5000 