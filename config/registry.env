# Registry Configuration
# The registry is accessible on port 32000 (NodePort), not 5000

# External registry URL (for Docker commands)
REGISTRY_URL=localhost:32000

# Internal registry URL (for Kubernetes deployments)
REGISTRY_INTERNAL=localhost:5000

# Registry service name
REGISTRY_SERVICE=registry

# Registry namespace
REGISTRY_NAMESPACE=default

# Registry NodePort
REGISTRY_NODEPORT=32000

# Registry internal port
REGISTRY_INTERNAL_PORT=5000 