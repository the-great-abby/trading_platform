# Paper Trading Status
paper-trading-status:
	@echo "🔍 Checking Paper Trading System Status..."
	@echo ""
	@echo "📊 Service Health:"
	@curl -s http://localhost:11115/api/paper-trading/status 2>/dev/null | jq -r '.status // "❌ Service Unavailable"' || echo "❌ Service Unavailable"
	@echo ""
	@echo "💰 Portfolio Value:"
	@curl -s http://localhost:11115/api/paper-trading/portfolio 2>/dev/null | jq -r 'if .total_value then "$$\(.total_value | tonumber | floor)" else "❌ Cannot Retrieve" end' || echo "❌ Cannot Retrieve Portfolio"
	@echo ""
	@echo "📈 Active Strategies:"
	@curl -s http://localhost:11115/api/paper-trading/strategies 2>/dev/null | jq -r '.strategies[] | select(.enabled) | "✅ \(.name)"' || echo "❌ Cannot Retrieve Strategies"
	@echo ""
	@echo "📊 Total Trades:"
	@curl -s http://localhost:11115/api/paper-trading/trades 2>/dev/null | jq -r '.total_trades // "0"' || echo "0"
	@echo ""
	@echo "🎯 P&L Summary:"
	@curl -s http://localhost:11115/api/paper-trading/performance 2>/dev/null | jq -r 'if .total_pnl then "$$\(.total_pnl | tonumber | floor)" else "$$0" end' || echo "$$0"

# Paper Trading Health Check
paper-trading-health:
	@echo "🏥 Paper Trading Health Check..."
	@if curl -s http://localhost:11115/api/paper-trading/status >/dev/null 2>&1; then \
		echo "✅ Service: Healthy"; \
	else \
		echo "❌ Service: Unhealthy"; \
		exit 1; \
	fi
	@if curl -s http://localhost:11115/api/paper-trading/portfolio | jq -e '.total_value' >/dev/null 2>&1; then \
		echo "✅ Portfolio: Accessible"; \
	else \
		echo "❌ Portfolio: Not Accessible"; \
		exit 1; \
	fi

# Start Paper Trading Service
paper-trading-start:
	@echo "🚀 Starting Live Data Options Paper Trading Service..."
	@echo ""
	@echo "📋 This will:"
	@echo "   • Start the live data options paper trading engine"
	@echo "   • Use REAL market data when available"
	@echo "   • Fall back to realistic simulated data if needed"
	@echo "   • Initialize portfolio with $4,000 capital"
	@echo "   • Activate Iron Condor, Butterfly, Calendar, Straddle, Strangle strategies"
	@echo "   • Begin realistic options trading with live pricing"
	@echo ""
	@echo "⏰ Trading interval: 60 seconds"
	@echo "💰 Initial Capital: $4,000"
	@echo "📊 Live Data: Enabled (with fallback)"
	@echo ""
	@echo "🛑 To stop: make paper-trading-stop"
	@echo "📊 To monitor: make paper-trading-monitor"
	@echo ""
	@python3 scripts/live_data_options_paper_trading_engine.py &
	@echo ""
	@echo "🔌 Setting up port forwarding..."
	@pkill -f "kubectl port-forward.*unified-trading-dashboard" 2>/dev/null || true
	@kubectl port-forward -n trading-system svc/unified-trading-dashboard 11115:80 > /dev/null 2>&1 &
	@sleep 3
	@echo "✅ Live Data Options Paper Trading Service started"
	@echo "🌐 Dashboard available at: http://localhost:11115/"

# Stop Paper Trading Service
paper-trading-stop:
	@echo "🛑 Stopping Live Data Options Paper Trading Service..."
	@pkill -f "live_data_options_paper_trading_engine.py" 2>/dev/null || true
	@pkill -f "options_paper_trading_engine.py" 2>/dev/null || true
	@pkill -f "setup_paper_trading.py" 2>/dev/null || true
	@pkill -f "kubectl port-forward.*unified-trading-dashboard" 2>/dev/null || true
	@echo "✅ Live Data Options Paper Trading Service stopped"

# Restart Paper Trading Service
paper-trading-restart:
	@echo "🔄 Restarting Paper Trading Service..."
	@make paper-trading-stop
	@sleep 2
	@make paper-trading-start
	@echo "✅ Paper Trading Service restarted"

