	@echo "🔍 Backtest Validation Framework Commands:"
	@echo ""
	@echo "  🚀 Local Testing (Recommended for Development):"
	@echo "    validation-test-local       - Test framework with local filesystem"
	@echo "    validation-run-local        - Run framework locally (filesystem mode)"
	@echo "    validation-quick-test       - Run quick validation test suite"
	@echo "    validation-health-local     - Check local framework health"
	@echo "    validation-api-test         - Test API endpoints locally"
	@echo ""
	@echo "  🔍 Discovery & Validation:"
	@echo "    validation-discover         - Discover scripts (first 20)"
	@echo "    validation-discover-all     - Discover all scripts"
	@echo "    validation-discover-json    - Discover scripts as JSON"
	@echo "    validation-validate-sample  - Validate sample script"
	@echo ""
	@echo "  🎯 Target Specific Scripts:"
	@echo "    validation-find-script      - Find scripts by pattern (NAME=pattern)"
	@echo "    validation-validate         - Validate by ID (SCRIPT_ID=id)"
	@echo "    validation-validate-by-name - Validate by name (NAME=name)"
	@echo "    validation-validate-by-path - Validate by path (PATH=path)"
	@echo "    validation-validate-specific - Advanced targeting (NAME|PATH|ID|SEARCH)"
	@echo "    validation-list-scripts     - List all scripts (PATTERN=optional)"
	@echo ""
	@echo "  📊 Batch & Reports:"
	@echo "    validation-batch-sample     - Batch validate sample scripts"
	@echo "    validation-batch            - Batch validate directory (DIR=path)"
	@echo "    validation-report-sample    - Generate sample report"
	@echo "    validation-report           - Generate report (FORMAT=json|table)"
	@echo ""
	@echo "  🧪 Testing:"
	@echo "    validation-test             - Run full validation tests"
	@echo "    validation-test-discovery   - Test script discovery"
	@echo "    validation-test-execution   - Test script execution"
	@echo "    validation-test-api         - Test validation API"
	@echo "    validation-test-integration - Test validation integration"
	@echo ""
	@echo "  🏗️ Build & Deploy (Kubernetes):"
	@echo "    validation-build            - Build Docker image"
	@echo "    validation-deploy           - Deploy to Kubernetes"
	@echo "    validation-stop             - Stop Kubernetes deployment"
	@echo "    validation-run              - Run locally (default mode)"
	@echo ""
	@echo "  📊 Monitoring:"
	@echo "    validation-health           - Check framework health (K8s)"
	@echo "    validation-health-local     - Check framework health (local)"
	@echo "    validation-metrics          - Get framework metrics"
	@echo "    validation-status           - Get framework status"
	@echo "    validation-active           - Get active validations"
	@echo ""
	@echo "  🔧 Development:"
	@echo "    validation-dev-setup        - Set up development environment"
	@echo "    validation-dev-test         - Run development tests"
	@echo "    validation-dev-lint         - Lint framework code"
	@echo "    validation-dev-format       - Format framework code"
	@echo "    validation-config-test      - Test framework configuration"
	@echo ""
	@echo "  🌐 Port Forwarding (Kubernetes):"
	@echo "    validation-port-forward     - Port forward service (localhost:11080)"
	@echo "    validation-port-stop        - Stop port forwarding"
	@echo ""
	@echo "💡 Quick Start for Local Testing:"
	@echo "  1. make validation-quick-test     # Run quick test suite"
	@echo "  2. make validation-discover       # Discover your scripts"
	@echo "  3. make validation-find-script NAME=Strategy # Find specific scripts"
	@echo "  4. make validation-validate-by-name NAME=Strategy_Allocation # Validate specific script"
	@echo "  5. make validation-run-local      # Start local API server"
	@echo ""
	@echo "🎯 Target Specific Backtests:"
	@echo "  make validation-find-script NAME=YourPattern    # Find scripts"
	@echo "  make validation-validate-by-name NAME=YourScript # Validate by name"
	@echo "  python scripts/validate_specific_script.py --list YourPattern # Advanced search"
