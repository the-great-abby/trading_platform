# Trade Recommendation Help
recommendations-help: ## Show trade recommendation help
	@echo "$(GREEN)🎯 TRADE RECOMMENDATION SYSTEM$(NC)"
	@echo "$(YELLOW)=============================$(NC)"
	@echo ""
	@echo "$(GREEN)Available Commands:$(NC)"
	@echo ""
	@echo "$(YELLOW)Multi-Timeframe:$(NC)"
	@echo "  recommendations-multi - Multi-timeframe analysis (Daily+Hourly+15m) - 10 results"
	@echo ""
	@echo "$(YELLOW)Individual Timeframes:$(NC)"
	@echo "  recommendations-daily   - Daily timeframe (1D candles, swing trading) - 10 results"
	@echo "  recommendations-hourly  - Hourly timeframe (1H candles, momentum) - 10 results"
	@echo "  recommendations-4h      - 4-Hour timeframe (4H candles, position) - 10 results"
	@echo "  recommendations-15m     - 15-minute timeframe (day trading) - 10 results"
	@echo "  recommendations-intraday - Intraday aggressive (1H aggressive) - 10 results"
	@echo ""
	@echo "$(YELLOW)General:$(NC)"
	@echo "  recommendations         - Get top 5 trade recommendations"
	@echo "  recommendations-all     - Get all available recommendations (up to 10)"
	@echo "  recommendations-quick   - Get quick top 3 recommendations"
	@echo "  recommendation          - Get recommendation for specific symbol"
	@echo "  recommendations-help    - Show this help"
	@echo ""
	@echo "$(GREEN)Examples:$(NC)"
	@echo ""
	@echo "$(YELLOW)Multi-Timeframe Analysis (Best for timing):$(NC)"
	@echo "  make recommendations-multi              # Get 10 multi-timeframe recommendations"
	@echo "  make recommendations-multi SYMBOL=AAPL  # Multi-timeframe for specific symbol"
	@echo ""
	@echo "$(YELLOW)Individual Timeframe Analysis:$(NC)"
	@echo "  make recommendations-daily              # Daily trend (swing trading)"
	@echo "  make recommendations-hourly             # Hourly momentum (momentum trading)"
	@echo "  make recommendations-4h                 # 4-hour position (position trading)"
	@echo "  make recommendations-15m                # 15-minute timing (day trading)"
	@echo "  make recommendations-intraday           # Intraday aggressive (day trading)"
	@echo ""
	@echo "$(YELLOW)With Specific Symbol:$(NC)"
	@echo "  make recommendations-daily SYMBOL=AAPL  # Daily analysis for AAPL"
	@echo "  make recommendations-hourly SYMBOL=TSLA # Hourly analysis for TSLA"
	@echo ""
	@echo "$(YELLOW)General Commands:$(NC)"
	@echo "  make recommendations"
	@echo "  make recommendations TIMEFRAME=1D"
	@echo "  make recommendations-all TIMEFRAME=4H"
	@echo "  make recommendation SYMBOL=AAPL"
	@echo ""
	@echo "$(GREEN)Supported Timeframes:$(NC)"
	@echo "  1m  - 1 minute"
	@echo "  5m  - 5 minutes"
	@echo "  15m - 15 minutes"
	@echo "  1H  - 1 hour"
	@echo "  4H  - 4 hours"
	@echo "  1D  - 1 day (default)"
	@echo "  1W  - 1 week"
	@echo "  1M  - 1 month"
	@echo ""
	@echo "$(GREEN)How It Works:$(NC)"
	@echo "  • Combines Elliott Wave analysis with strategy signals"
	@echo "  • Analyzes market conditions and risk factors"
	@echo "  • Provides confidence scores and detailed reasoning"
	@echo "  • Ranks recommendations by overall score"
	@echo "  • Supports multiple timeframes for multi-timeframe analysis"
	@echo ""
	@echo "$(GREEN)Recommendation Levels:$(NC)"
	@echo "  🟢 STRONG BUY  - Score > 60"
	@echo "  🟡 BUY         - Score 40-60"
	@echo "  🟠 HOLD        - Score 20-40"
	@echo "  🔴 WEAK SELL   - Score 0-20"
	@echo "  🔴 SELL        - Score < 0"

# Enhanced Recommendations (Multi-Indicator + Elliott Wave)
recommendations-enhanced: ## Get enhanced recommendations with RSI, MACD, MA, Volume, BB, Ichimoku
	@echo "🚀 ENHANCED TRADE RECOMMENDATIONS"
	@echo "===================================="
	@echo ""
	@echo "📊 Analyzing with Multi-Indicator System (RSI + MACD + MA + Volume + BB + Ichimoku)..."
	@echo ""
	@curl -s "http://localhost:11001/api/trading/recommendations/enhanced?limit=10" | jq -r '.recommendations[] | "🎯 " + .symbol + " @ $$" + (.current_price | tostring) + " - " + .action + " (Score: " + (.score | tostring) + ")"'
	@echo ""
	@curl -s "http://localhost:11001/api/trading/recommendations/enhanced?limit=10" | jq -r '.recommendations[] | "   Confidence: " + ((.confidence * 100 | floor) | tostring) + "% | RSI: " + (.technical_indicators.rsi.value | tostring) + " | MACD: " + .technical_indicators.macd.interpretation + " | Trend: " + .technical_indicators.moving_averages.trend'
	@echo ""
	@curl -s "http://localhost:11001/api/trading/recommendations/enhanced?limit=10" | jq -r '.recommendations[] | "   Ichimoku: Kijun $$" + (.technical_indicators.ichimoku.kijun_sen | tostring) + " | Tenkan $$" + (.technical_indicators.ichimoku.tenkan_sen | tostring) + " | " + .technical_indicators.ichimoku.cloud_position + " cloud | TK " + .technical_indicators.ichimoku.tk_cross'
	@echo ""

# Scan for Recent Patterns  
recommendations-scan: ## Scan for symbols with recent Elliott Wave patterns
	@echo "🔍 RECENT PATTERN SCANNER"
	@echo "========================="
	@curl -s "http://localhost:11001/api/trading/scan/recent-patterns?max_age_days=60&limit=10" | jq -r '.message' 2>/dev/null || echo "❌ Error"
	@curl -s "http://localhost:11001/api/trading/scan/recent-patterns?max_age_days=60&limit=10" | jq -r '.patterns[] | "✅ " + .symbol + " - " + .signal + " (Age: " + (.pattern_age_days | tostring) + " days)"' 2>/dev/null || echo "No patterns found"
	@echo ""

