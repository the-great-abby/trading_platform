# Simple Collaboration Makefile
# For 2-person development team - Core collaboration and status commands

# =====================================================================
# 🚀 CORE COLLABORATION COMMANDS
# =====================================================================

.PHONY: simple-help simple-status simple-sync simple-startup simple-progress simple-learning simple-blocker simple-session-summary simple-daily-sync simple-fix-bug simple-test-priority simple-dynamic-health simple-ai-review simple-ai-refactor simple-ai-test simple-ai-docs simple-ai-optimize simple-ai-security simple-ai-setup simple-ai-debug simple-ai-workflow simple-ai-help

# Colors for output
GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

simple-help: ## Show this help message
	@echo "$(GREEN)🚀 Trading Platform Development Commands$(NC)"
	@echo "$(YELLOW)==========================================$(NC)"
	@echo ""
	@echo "$(GREEN)Project Status:$(NC)"
	@echo "  simple-status         - Show current project status and progress"
	@echo "  simple-sync           - Quick team sync with current status"
	@echo "  simple-startup        - Quick session startup"
	@echo "  simple-progress       - Show detailed progress on all areas"
	@echo "  simple-learning       - Show learning progress and next steps"
	@echo "  simple-blocker        - Report and track blockers"
	@echo "  simple-session-summary - Get summary of current session work"
	@echo "  simple-daily-sync     - Daily sync routine"
	@echo ""
	@echo "$(GREEN)Development Workflow:$(NC)"
	@echo "  simple-fix-bug        - Quick workflow for fixing a bug"
	@echo "  simple-test-priority  - Show testing priorities"
	@echo "  simple-dynamic-health - Run dynamic health check (tests real connectivity)"
	@echo ""
	@echo "$(GREEN)AI-Assisted Development:$(NC)"
	@echo "  simple-ai-review      - AI code review with context from all rules"
	@echo "  simple-ai-refactor    - AI-assisted refactoring using style rules"
	@echo "  simple-ai-test        - AI test generation with comprehensive coverage"
	@echo "  simple-ai-docs        - AI documentation updates and improvements"
	@echo "  simple-ai-optimize    - AI performance optimization suggestions"
	@echo "  simple-ai-security    - AI security scanning and best practices"
	@echo "  simple-ai-setup       - AI-assisted new service setup with all relevant rules"
	@echo "  simple-ai-debug       - AI-assisted debugging with comprehensive analysis"
	@echo "  simple-ai-workflow    - AI-assisted development workflow optimization"
	@echo "  simple-ai-help        - Show all AI-assisted development commands"
	@echo ""
	@echo "$(BLUE)💡 Use 'make <target>' to run any command$(NC)"
	@echo "$(BLUE)💡 Use 'make -n <target>' to see what a command would do$(NC)"
	@echo ""
	@echo "$(YELLOW)📋 For other operations, use specialized Makefiles:$(NC)"
	@echo "  make -f Makefile.services <target>  - Service management"
	@echo "  make -f Makefile.kubernetes <target> - Kubernetes operations"
	@echo "  make -f Makefile.port-forward <target> - Port forwarding"

# =====================================================================
# 📊 PROJECT STATUS & COLLABORATION
# =====================================================================

simple-status: ## Show current status (dynamic health check)
	@echo "$(GREEN)🔍 RUNNING DYNAMIC HEALTH CHECK...$(NC)"
	@echo "$(YELLOW)=====================================$(NC)"
	@echo "$(BLUE)⏳ Testing real connectivity (not just pod status)...$(NC)"
	@echo ""
	@cd scripts && python3 -m pip install -r requirements_health_check.txt --quiet > /dev/null 2>&1 || true
	@cd scripts && python3 dynamic_health_check.py
	@echo ""
	@echo "$(YELLOW)💡 TIP: Use 'make dynamic-health' for detailed health reports$(NC)"
	@echo "$(BLUE)📊 This status shows REAL connectivity, not just deployment status$(NC)"

simple-sync: ## Quick sync questions
	@echo "$(GREEN)🤝 Quick sync questions...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py sync

simple-startup: ## Quick session startup
	@echo "$(GREEN)🚀 Starting new session...$(NC)"
	docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/session_startup.py

simple-progress: ## Log progress (usage: make progress task="Task Name" status="Status")
	@echo "$(GREEN)📝 Logging progress...$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py progress "$(task)" "$(status)"

simple-learning: ## Log learning (usage: make learning topic="Topic" discovery="Discovery")
	@echo "$(GREEN)💡 Logging learning...$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py learning "$(topic)" "$(discovery)"

simple-blocker: ## Log blocker (usage: make blocker task="Task" blocker="Blocker")
	@echo "$(GREEN)🚨 Logging blocker...$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py blocker "$(task)" "$(blocker)"

simple-session-summary: ## Get summary of current session work
	@echo "$(GREEN)📋 Session Summary:$(NC)"
	@docker-compose -f docker-compose.dev.yml run --rm trading-cli python scripts/simple_collaboration.py session_summary

simple-daily-sync: ## Daily sync routine
	@echo "$(GREEN)🤝 Daily Sync Routine:$(NC)"
	@echo "1. What did you accomplish yesterday?"
	@echo "2. What are you working on today?"
	@echo "3. Any blockers or issues?"
	@echo "4. Any discoveries or learnings?"
	@echo "5. What's your next priority?"

# =====================================================================
# 🔧 DEVELOPMENT WORKFLOW
# =====================================================================

simple-fix-bug: ## Quick workflow for fixing a bug
	@echo "$(GREEN)🐛 Bug fixing workflow:$(NC)"
	@echo "1. Reproduce the bug"
	@echo "2. Use differential coverage to find location"
	@echo "3. Write minimal test case"
	@echo "4. Fix the bug"
	@echo "5. Verify fix works"
	@echo "6. Document the fix"

simple-test-priority: ## Show testing priorities
	@echo "$(GREEN)🎯 Testing Priorities:$(NC)"
	@echo "1. Trading Engine (Priority: 10/10)"
	@echo "2. Risk Management (Priority: 9/10)"
	@echo "3. Authentication (Priority: 9/10)"
	@echo "4. Order Execution (Priority: 8/10)"
	@echo "5. Market Data (Priority: 7/10)"

simple-dynamic-health: ## Run dynamic health check (tests real connectivity, not just pod status)
	@echo "🔍 Running dynamic health check (tests real connectivity)..."
	@cd scripts && python3 -m pip install -r requirements_health_check.txt --quiet
	@cd scripts && python3 dynamic_health_check.py

# =====================================================================
# 🤖 AI-ASSISTED DEVELOPMENT COMMANDS
# =====================================================================
# Making AI a first-class citizen in the development process

simple-ai-review: ## AI-assisted code review with context from all rules
	@echo "$(GREEN)🤖 AI Code Review - Making AI a First-Class Citizen$(NC)"
	@echo "$(YELLOW)==================================================$(NC)"
	@echo ""
	@echo "$(GREEN)🔄 Starting AI code review...$(NC)"
	@echo "$(YELLOW)💡 AI will analyze your current working directory and suggest improvements$(NC)"
	@echo "$(BLUE)📚 AI will reference: Core Rules + AI Development Assistant + Domain Rules$(NC)"
	@echo ""
	@if [ -f "scripts/ai_code_review.py" ]; then \
		python3 scripts/ai_code_review.py --path . --rules all --ollama-url http://localhost:12001 --callback-port 11999; \
	else \
		echo "$(RED)❌ AI Code Review script not found. Creating it now...$(NC)"; \
		echo "$(YELLOW)💡 Run 'make ai-review' again after the script is created.$(NC)"; \
	fi

