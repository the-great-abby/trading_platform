# Kubernetes Operations Makefile
# Usage: make -f Makefile.kubernetes <target>

GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
NC := \033[0m # No Color
KUBECTL := kubectl
NAMESPACE := trading-system

k8s-deploy: ## Deploy all services to Kubernetes
	@echo "$(GREEN)Deploying all services to Kubernetes...$(NC)"
	@$(KUBECTL) apply -f k8s/

k8s-deploy-backtest-api: ## Deploy backtest API service
	@echo "$(GREEN)Deploying backtest API service...$(NC)"
	@$(KUBECTL) apply -f k8s/backtest-api.yaml
	@$(KUBECTL) apply -f k8s/ingress.yaml

k8s-deploy-strategy-service: ## Deploy strategy service
	@echo "$(GREEN)Deploying strategy service...$(NC)"
	@$(KUBECTL) apply -f k8s/strategy-service.yaml
	@$(KUBECTL) apply -f k8s/ingress.yaml

k8s-see-allocated-resources:
	kubectl describe nodes | grep -A 10 "Allocated resources"

k8s-deploy-market-data-worker: ## Deploy market data worker
	@echo "$(GREEN)Deploying market data worker...$(NC)"
	@$(KUBECTL) apply -f k8s/market-data-worker.yaml

k8s-port-forward-backtest: ## Port forward backtest API to localhost
	@echo "$(GREEN)Port forwarding backtest API to localhost:10001...$(NC)"
	@$(KUBECTL) port-forward svc/backtest-api 10001:10001 -n $(NAMESPACE)

k8s-port-forward-strategy: ## Port forward strategy service to localhost
	@echo "$(GREEN)Port forwarding strategy service to localhost:11003...$(NC)"
	@$(KUBECTL) port-forward svc/strategy-service 11003:80 -n $(NAMESPACE)

k8s-logs-backtest: ## Show logs for backtest API
	@echo "$(GREEN)Showing logs for backtest API...$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) logs --tail=50 --follow deployment/backtest-api

k8s-status-backtest: ## Show status of backtest API pods
	@echo "$(GREEN)Backtest API pod status:$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) get pods -l app=backtest-api

k8s-status-strategy: ## Show status of strategy service pods
	@echo "$(GREEN)Strategy service pod status:$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) get pods -l app=strategy-service

k8s-status-market-data-worker: ## Show status of market data worker pods
	@echo "$(GREEN)Market data worker pod status:$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) get pods -l app=market-data-worker

k8s-logs-market-data-worker: ## Show logs for market data worker
	@echo "$(GREEN)Showing logs for market data worker...$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) logs --tail=50 --follow deployment/market-data-worker

k8s-logs: ## Show logs for all pods
	@echo "$(GREEN)Showing logs for all pods...$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) logs --tail=50 --all-containers=true --selector app

k8s-status: ## Show status of all pods
	@echo "$(GREEN)Kubernetes pod status:$(NC)"
	@$(KUBECTL) -n $(NAMESPACE) get pods

k8s-clean: ## Delete all resources in the namespace
	@echo "$(GREEN)Deleting all resources in namespace $(NAMESPACE)...$(NC)"
	@$(KUBECTL) delete all --all -n $(NAMESPACE)

k8s-help: ## Show this help message
	@echo "$(GREEN)Kubernetes Operations:$(NC)"
	@grep -E '^k8s-[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | sort | awk 'BEGIN {FS = ":.*?## "}; {printf "  $(YELLOW)%-30s$(NC) %s\n", $$1, $$2}'

# Job Generation
k8s-job-backtest:
	@echo "Generating backtest job..."
	@source k8s-job-generator-env/bin/activate && python3 scripts/generate_k8s_job.py --type backtest --script $(SCRIPT) \
		$(if $(NAME),--name $(NAME)) \
		$(if $(SYMBOLS),--symbols $(SYMBOLS)) \
		$(if $(START_DATE),--start-date $(START_DATE)) \
		$(if $(END_DATE),--end-date $(END_DATE)) \
		$(if $(USE_LLM),--use-llm) \
		$(if $(MEMORY_REQUEST),--memory-request $(MEMORY_REQUEST)) \
		$(if $(MEMORY_LIMIT),--memory-limit $(MEMORY_LIMIT)) \
		$(if $(CPU_REQUEST),--cpu-request $(CPU_REQUEST)) \
		$(if $(CPU_LIMIT),--cpu-limit $(CPU_LIMIT)) \
		$(if $(APPLY),--apply) \
		$(if $(OUTPUT),--output $(OUTPUT))

k8s-job-analysis:
	@echo "Generating analysis job..."
	@source k8s-job-generator-env/bin/activate && python3 scripts/generate_k8s_job.py --type analysis --script $(SCRIPT) \
		$(if $(NAME),--name $(NAME)) \
		$(if $(MEMORY_REQUEST),--memory-request $(MEMORY_REQUEST)) \
		$(if $(MEMORY_LIMIT),--memory-limit $(MEMORY_LIMIT)) \
		$(if $(CPU_REQUEST),--cpu-request $(CPU_REQUEST)) \
		$(if $(CPU_LIMIT),--cpu-limit $(CPU_LIMIT)) \
		$(if $(APPLY),--apply) \
		$(if $(OUTPUT),--output $(OUTPUT))

k8s-job-data:
	@echo "Generating data job..."
	@source k8s-job-generator-env/bin/activate && python3 scripts/generate_k8s_job.py --type data --script $(SCRIPT) \
		$(if $(NAME),--name $(NAME)) \
		$(if $(MEMORY_REQUEST),--memory-request $(MEMORY_REQUEST)) \
		$(if $(MEMORY_LIMIT),--memory-limit $(MEMORY_LIMIT)) \
		$(if $(CPU_REQUEST),--cpu-request $(CPU_REQUEST)) \
		$(if $(CPU_LIMIT),--cpu-limit $(CPU_LIMIT)) \
		$(if $(APPLY),--apply) \
		$(if $(OUTPUT),--output $(OUTPUT))

# Quick job generation examples
k8s-quick-backtest:
	@echo "$(GREEN)Running quick backtest job...$(NC)"
	@make k8s-job-backtest SCRIPT=scripts/backtest_cli.py NAME=quick-backtest SYMBOLS=AAPL,MSFT,GOOGL START_DATE=2024-01-01 END_DATE=2024-12-31 APPLY=true

k8s-quick-analysis:
	@echo "$(GREEN)Running quick analysis job...$(NC)"
	@make k8s-job-analysis SCRIPT=scripts/analyze_winning_strategies.py NAME=quick-analysis APPLY=true

k8s-quick-data:
	@echo "$(GREEN)Running quick data job...$(NC)"
	@make k8s-job-data SCRIPT=scripts/fetch_and_store_polygon_data.py NAME=quick-data APPLY=true

.PHONY: k8s-deploy k8s-deploy-backtest-api k8s-deploy-strategy-service k8s-deploy-market-data-worker k8s-port-forward-backtest k8s-port-forward-strategy k8s-logs-backtest k8s-status-backtest k8s-status-strategy k8s-status-market-data-worker k8s-logs-market-data-worker k8s-logs k8s-status k8s-clean k8s-help k8s-job-backtest k8s-job-analysis k8s-job-data k8s-quick-backtest k8s-quick-analysis k8s-quick-data 

.PHONY: k8s-port-forward-start k8s-port-forward-stop k8s-port-forward-restart k8s-port-forward-status k8s-port-forward-attach k8s-port-forward-help

# Port Forwarding Commands (using existing tmux structure)
k8s-port-forward-start:
	@echo "🚀 Starting comprehensive tmux port forward session..."
	@./scripts/portforward_tmux.sh

k8s-port-forward-stop:
	@echo "🛑 Stopping tmux port forward session..."
	tmux kill-session -t k8s-portforwards 2>/dev/null || echo "Session not running"

k8s-port-forward-restart:
	@echo "🔄 Restarting tmux port forward session..."
	$(MAKE) k8s-port-forward-stop
	sleep 2
	$(MAKE) k8s-port-forward-start

k8s-port-forward-status:
	@if tmux has-session -t k8s-portforwards 2>/dev/null; then \
		echo "✅ Session 'k8s-portforwards' is running"; \
		echo "📋 Attach: tmux attach-session -t k8s-portforwards"; \
		echo "🛑 Stop: make k8s-port-forward-stop"; \
		echo ""; \
		echo "📡 Active Port Forwards:"; \
		tmux list-windows -t k8s-portforwards; \
	else \
		echo "❌ Session 'k8s-portforwards' is not running"; \
		echo "🚀 Start: make k8s-port-forward-start"; \
	fi

k8s-port-forward-attach:
	@echo "📋 Attaching to tmux session..."
	tmux attach-session -t k8s-portforwards

# Simple Port Forwarding (without tmux)
k8s-port-forward-simple:
	@echo "📡 Starting simple port forward..."
	kubectl port-forward service/trading-ultra-service 11100:80 -n trading-system --address=0.0.0.0

# Help
k8s-port-forward-help:
	@echo "📡 Kubernetes Port Forwarding Commands:"
	@echo "  make k8s-port-forward-start       - Start comprehensive tmux port forward session"
	@echo "  make k8s-port-forward-stop        - Stop tmux port forward session"
	@echo "  make k8s-port-forward-restart     - Restart tmux port forward session"
	@echo "  make k8s-port-forward-status      - Check tmux session status"
	@echo "  make k8s-port-forward-attach      - Attach to tmux session"
	@echo "  make k8s-port-forward-simple      - Start simple port forward"
	@echo ""
	@echo "📋 Direct Script Usage:"
	@echo "  ./scripts/portforward_tmux.sh"
	@echo "  tmux attach-session -t k8s-portforwards"
	@echo "  tmux kill-session -t k8s-portforwards"
	@echo ""
	@echo "📡 Available Services:"
	@echo "  central-hub-dashboard:11080"
	@echo "  trading-gateway:11081"
	@echo "  trading-dashboard:11082"
	@echo "  health-dashboard:11083"
	@echo "  performance-dashboard:11084"
	@echo "  rss-dashboard:11085"
	@echo "  report-viewer-service:11086"

# Learning and Practice Commands
k8s-learn-exercises: ## Run interactive Kubernetes learning exercises
	@echo "🎓 Starting Kubernetes learning exercises..."
	@./scripts/k8s-learning-exercises.sh

k8s-quickstart: ## Start your Kubernetes learning journey
	@echo "🚀 Starting Kubernetes Learning Quick Start..."
	@./scripts/k8s-learning-quickstart.sh

k8s-learn-preview: ## Preview the comprehensive learning guide
	@echo "📚 Previewing Kubernetes Learning Guide..."
	@head -50 docs/KUBERNETES_LEARNING_GUIDE.md

k8s-learn: ## Open the full learning guide in editor
	@echo "📚 Opening Kubernetes Learning Guide..."
	@open docs/KUBERNETES_LEARNING_GUIDE.md || code docs/KUBERNETES_LEARNING_GUIDE.md || vim docs/KUBERNETES_LEARNING_GUIDE.md

k8s-command-ref: ## Open the command reference guide
	@echo "📋 Opening Kubernetes Command Reference..."
	@open KUBERNETES_COMMAND_REFERENCE.md || code KUBERNETES_COMMAND_REFERENCE.md || vim KUBERNETES_COMMAND_REFERENCE.md

k8s-learning-plan: ## Open your personalized learning plan
	@echo "🎯 Opening Kubernetes Learning Plan..."
	@open KUBERNETES_LEARNING_PLAN.md || code KUBERNETES_LEARNING_PLAN.md || vim KUBERNETES_LEARNING_PLAN.md

# AI IDE Integration Commands
k8s-ai-ide-setup: ## Set up AI IDE integration with local LLM and architecture database
	@echo "🧠 Setting up AI IDE integration..."
	@./scripts/setup-ai-ide-integration.sh

k8s-ai-ide-deploy: ## Deploy AI IDE service to Kubernetes
	@echo "🚀 Deploying AI IDE service..."
	@kubectl apply -f k8s/ai-ide-service.yaml
	@kubectl wait --for=condition=available --timeout=300s deployment/ai-ide-service -n trading-system

k8s-ai-ide-port-forward: ## Port forward AI IDE service for local access
	@echo "📡 Port forwarding AI IDE service..."
	@kubectl port-forward service/ai-ide-service 11050:11050 -n trading-system

k8s-ai-ide-status: ## Check AI IDE service status
	@echo "📊 AI IDE Service Status:"
	@kubectl get pods -n trading-system | grep ai-ide-service
	@echo ""
	@echo "🔍 Service Health:"
	@curl -s http://localhost:11050/api/health 2>/dev/null || echo "Service not accessible"

k8s-ai-ide-logs: ## View AI IDE service logs
	@echo "📋 AI IDE Service Logs:"
	@kubectl logs deployment/ai-ide-service -n trading-system --tail=50

k8s-ai-ide-models: ## List available Ollama models
	@echo "🤖 Available Ollama Models:"
	@curl -s http://localhost:11050/api/models 2>/dev/null || echo "AI IDE service not accessible"

k8s-ai-ide-test: ## Test AI IDE service with sample requests
	@echo "🧪 Testing AI IDE Service..."
	@echo "1. Health Check:"
	@curl -s http://localhost:11050/api/health
	@echo ""
	@echo "2. Available Models:"
	@curl -s http://localhost:11050/api/models
	@echo ""
	@echo "3. Architecture Query Test:"
	@curl -X POST http://localhost:11050/api/query-architecture \
		-H "Content-Type: application/json" \
		-d '{"question": "What is our trading system architecture?", "include_code_examples": true}' 2>/dev/null || echo "Service not accessible"

k8s-ai-ide-test-comprehensive: ## Run comprehensive AI IDE integration test
	@echo "🧪 Running comprehensive AI IDE test..."
	@python3 scripts/test-ai-ide-integration.py

# External Database Testing Commands
k8s-test-external-dbs: ## Test connectivity to external databases
	@echo "🗄️ Testing external database connectivity..."
	@echo "1. Testing Vector Storage External..."
	@kubectl run test-vector --image=curlimages/curl --rm -it --restart=Never -- \
		curl -v http://postgres-vector-external.postgres-infra.svc.cluster.local:5432/health 2>/dev/null || echo "Vector storage not accessible"
	@echo ""
	@echo "2. Testing TimescaleDB External..."
	@kubectl run test-timescale --image=postgres:15 --rm -it --restart=Never -- \
		psql -h postgres-timescale-external.postgres-infra.svc.cluster.local -p 5432 -U trading_user -d trading_bot -c "SELECT 1;" 2>/dev/null || echo "TimescaleDB not accessible"
	@echo ""
	@echo "3. Testing Apache AGE External..."
	@kubectl run test-age --image=postgres:15 --rm -it --restart=Never -- \
		psql -h postgres-age-external.postgres-infra.svc.cluster.local -p 5432 -U trading_user -d trading_bot -c "SELECT 1;" 2>/dev/null || echo "Apache AGE not accessible"

k8s-check-external-db-services: ## Check external database services
	@echo "🔍 Checking external database services..."
	@echo "Services in postgres-infra namespace:"
	@kubectl get svc -n postgres-infra | grep external
	@echo ""
	@echo "Endpoints:"
	@kubectl get endpoints -n postgres-infra | grep external

# Quick Practice Commands
k8s-practice-basic: ## Practice basic Kubernetes operations
	@echo "🔧 Practicing basic Kubernetes operations..."
	@echo "1. Checking cluster info..."
	@kubectl cluster-info
	@echo ""
	@echo "2. Getting nodes..."
	@kubectl get nodes
	@echo ""
	@echo "3. Getting all resources in trading-system namespace..."
	@kubectl get all -n trading-system
	@echo ""
	@echo "4. Getting pods with wide output..."
	@kubectl get pods -n trading-system -o wide

k8s-practice-debug: ## Practice debugging commands
	@echo "🔍 Practicing debugging commands..."
	@echo "1. Getting recent events..."
	@kubectl get events -n trading-system --sort-by='.lastTimestamp' | head -10
	@echo ""
	@echo "2. Getting pod status..."
	@kubectl get pods -n trading-system
	@echo ""
	@echo "3. Getting service endpoints..."
	@kubectl get endpoints -n trading-system

k8s-practice-resources: ## Practice resource management commands
	@echo "📊 Practicing resource management..."
	@echo "1. Getting resource usage for pods..."
	@kubectl top pods -n trading-system 2>/dev/null || echo "Metrics server not available"
	@echo ""
	@echo "2. Getting resource usage for nodes..."
	@kubectl top nodes 2>/dev/null || echo "Metrics server not available"
	@echo ""
	@echo "3. Getting deployments with resource info..."
	@kubectl get deployments -n trading-system -o wide

# Quick Status Commands
k8s-status-all: ## Get comprehensive status of all resources
	@echo "📊 Comprehensive Kubernetes Status Report"
	@echo "========================================"
	@echo ""
	@echo "🔧 Cluster Info:"
	@kubectl cluster-info
	@echo ""
	@echo "🖥️  Nodes:"
	@kubectl get nodes
	@echo ""
	@echo "📦 Pods:"
	@kubectl get pods -n trading-system
	@echo ""
	@echo "🚀 Deployments:"
	@kubectl get deployments -n trading-system
	@echo ""
	@echo "🌐 Services:"
	@kubectl get services -n trading-system
	@echo ""
	@echo "⏰ Jobs:"
	@kubectl get jobs -n trading-system
	@echo ""
	@echo "🕐 CronJobs:"
	@kubectl get cronjobs -n trading-system
	@echo ""
	@echo "📋 ConfigMaps:"
	@kubectl get configmaps -n trading-system
	@echo ""
	@echo "🔐 Secrets:"
	@kubectl get secrets -n trading-system 