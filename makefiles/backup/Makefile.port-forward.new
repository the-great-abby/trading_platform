# 🚀 Port Forwarding Management for Trading System
# Maps all services to appropriate ports in the 11000-11999 range

.PHONY: help start-all stop-all status check-all ports port-watcher
.PHONY: start-dashboards start-monitoring start-data-services start-trading-services start-ai-services start-databases
.PHONY: start-unified-dashboards start-unified-analytics start-unified-trading start-unified-news
.PHONY: start-central-hub start-performance start-health start-rss start-ai-stock
.PHONY: start-trading-ultra start-market-data start-backtest start-backtest-request
.PHONY: start-grafana start-prometheus start-ollama start-llm-proxy
.PHONY: start-analytics start-data-pipeline start-timescaledb start-postgres start-redis start-rabbitmq

# Colors for output
GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

help: ## Show this help message
	@echo "$(GREEN)🚀 Trading System Port Forwarding Management$(NC)"
	@echo "$(YELLOW)============================================$(NC)"
	@echo ""
	@echo "$(GREEN)Basic Operations:$(NC)"
	@echo "  start-all       - Start all port forwarding"
	@echo "  stop-all        - Stop all port forwarding"
	@echo "  status          - Show status of all port forwards"
	@echo "  check-all       - Health check all services"
	@echo "  ports           - Manage port forwarding (start|stop|restart|status|test)"
	@echo "  port-watcher    - Start automated port forwarding for all services"
	@echo ""
	@echo "$(GREEN)Service Categories:$(NC)"
	@echo "  start-unified-dashboards - Start core unified dashboard services only"
	@echo "  start-dashboards - Start all dashboard services only"
	@echo "  start-monitoring - Start monitoring services only"
	@echo "  start-data-services - Start data processing services only"
	@echo "  start-trading-services - Start trading services only"
	@echo "  start-ai-services - Start AI/ML services only"
	@echo "  start-databases - Start database services only"
	@echo ""
	@echo "$(GREEN)Individual Services:$(NC)"
	@echo "  start-unified-analytics - Start Unified Analytics Dashboard"
	@echo "  start-unified-trading - Start Unified Trading Dashboard"
	@echo "  start-unified-news - Start Unified News Dashboard"
	@echo "  start-central-hub - Start Central Hub Dashboard"
	@echo "  start-performance - Start Performance Dashboard"
	@echo "  start-health - Start Health Dashboard"
	@echo "  start-rss - Start RSS Dashboard"
	@echo "  start-ai-stock - Start AI Stock Dashboard"
	@echo "  start-trading-ultra - Start Trading Ultra Service"
	@echo "  start-market-data - Start Market Data Service"
	@echo "  start-backtest - Start Backtest API"
	@echo "  start-backtest-request - Start Backtest Request Service"
	@echo "  start-grafana - Start Grafana monitoring"
	@echo "  start-prometheus - Start Prometheus metrics"
	@echo "  start-ollama - Start Ollama LLM"
	@echo "  start-llm-proxy - Start LLM Proxy"
	@echo "  start-analytics - Start Analytics Service"
	@echo "  start-data-pipeline - Start Data Pipeline"
	@echo "  start-timescaledb - Start TimescaleDB"
	@echo "  start-postgres - Start PostgreSQL"
	@echo "  start-redis - Start Redis"
	@echo "  start-rabbitmq - Start RabbitMQ"
	@echo ""
	@echo "$(BLUE)💡 All ports are in the 11000-11999 range to avoid conflicts$(NC)"

# =====================================================================
# 🛑 BASIC PORT FORWARDING OPERATIONS
# =====================================================================

stop-all: ## Stop all port forwarding
	@echo "$(GREEN)🛑 Stopping all port forwarding...$(NC)"
	@pkill -f "kubectl port-forward" || true
	@echo "$(GREEN)✅ All port forwarding stopped$(NC)"

status: ## Show status of all port forwards
	@echo "$(GREEN)📊 Port Forwarding Status:$(NC)"
	@echo "$(YELLOW)==========================$(NC)"
	@ps aux | grep "kubectl port-forward" | grep -v grep || echo "No active port forwards"

check-all: ## Health check all services
	@echo "$(GREEN)🔍 Health Checking All Services...$(NC)"
	@echo "$(YELLOW)================================$(NC)"
	@echo "$(BLUE)📊 Dashboards:$(NC)"
	@curl -s http://localhost:11080/health 2>/dev/null | grep -q "healthy" && echo "✅ Central Hub (11080)" || echo "❌ Central Hub (11080)"
	@curl -s http://localhost:11000/health 2>/dev/null | grep -q "healthy" && echo "✅ Performance (11000)" || echo "❌ Performance (11000)"
	@curl -s http://localhost:11002/health 2>/dev/null | grep -q "healthy" && echo "✅ Health (11002)" || echo "❌ Health (11002)"
	@curl -s http://localhost:11003/health 2>/dev/null | grep -q "healthy" && echo "✅ RSS Dashboard (11003)" || echo "❌ RSS Dashboard (11003)"
	@curl -s http://localhost:11115/health 2>/dev/null | grep -q "healthy" && echo "✅ Unified Analytics (11115)" || echo "❌ Unified Analytics (11115)"
	@curl -s http://localhost:11114/health 2>/dev/null | grep -q "healthy" && echo "✅ Unified Trading (11114)" || echo "❌ Unified Trading (11114)"
	@curl -s http://localhost:11113/health 2>/dev/null | grep -q "healthy" && echo "✅ Unified News (11113)" || echo "❌ Unified News (11113)"
	@echo ""
	@echo "$(BLUE)🔧 Services:$(NC)"
	@curl -s http://localhost:11099/health 2>/dev/null | grep -q "healthy" && echo "✅ Trading Ultra (11099)" || echo "❌ Trading Ultra (11099)"
	@curl -s http://localhost:11084/health 2>/dev/null | grep -q "healthy" && echo "✅ Market Data (11084)" || echo "❌ Market Data (11084)"
	@curl -s http://localhost:11101/health 2>/dev/null | grep -q "healthy" && echo "✅ Backtest API (11101)" || echo "❌ Backtest API (11101)"
	@curl -s http://localhost:11086/health 2>/dev/null | grep -q "healthy" && echo "✅ AI Stock (11086)" || echo "❌ AI Stock (11086)"
	@echo ""
	@echo "$(BLUE)📈 Monitoring:$(NC)"
	@curl -s http://localhost:11102/ 2>/dev/null | grep -q "Grafana" && echo "✅ Grafana (11102)" || echo "❌ Grafana (11102)"
	@curl -s http://localhost:11190/ 2>/dev/null | grep -q "Prometheus" && echo "✅ Prometheus (11190)" || echo "❌ Prometheus (11190)"

ports: ## Manage port forwarding (start|stop|restart|status|test)
	@echo "$(GREEN)🔌 Managing port forwarding...$(NC)"
	@if [ -z "$(action)" ]; then \
		echo "Usage: make ports action=<start|stop|restart|status|test>"; \
		echo "Example: make ports action=start"; \
	else \
		./scripts/port-forward-manager.sh $(action); \
	fi

port-watcher: ## Start automated port forwarding for all services
	@echo "$(GREEN)🚀 Starting Simple Port Forwarding for Trading System...$(NC)"
	@echo "$(YELLOW)📋 This will automatically manage port forwarding for essential services$(NC)"
	@echo "$(BLUE)🔌 Ports will be consistent: 11113, 11114, 11115, 11102, 11379, 11180, 11181, 11182$(NC)"
	@echo ""
	@cd scripts && ./simple-port-forward.sh start

# =====================================================================
# 🚀 START ALL PORT FORWARDING
# =====================================================================

start-all: stop-all ## Start all port forwarding
	@echo "$(GREEN)🚀 Starting all port forwarding...$(NC)"
	@echo "$(YELLOW)===============================$(NC)"
	@$(MAKE) start-dashboards
	@$(MAKE) start-monitoring
	@$(MAKE) start-data-services
	@$(MAKE) start-trading-services
	@$(MAKE) start-ai-services
	@$(MAKE) start-databases
	@echo ""
	@echo "$(GREEN)✅ All port forwarding started!$(NC)"
	@echo "$(BLUE)📊 Check status with: make status$(NC)"
	@echo "$(BLUE)🔍 Health check with: make check-all$(NC)"

# =====================================================================
# 📊 DASHBOARD SERVICES (11000-11099)
# =====================================================================

start-dashboards: ## Start all dashboard services
	@echo "$(GREEN)📊 Starting Dashboard Services...$(NC)"
	@$(MAKE) start-unified-dashboards
	@$(MAKE) start-central-hub
	@$(MAKE) start-performance
	@$(MAKE) start-health
	@$(MAKE) start-rss
	@$(MAKE) start-ai-stock
	@echo "$(GREEN)✅ All dashboard services started!$(NC)"

start-unified-dashboards: ## Start core unified dashboard services only
	@echo "$(GREEN)📊 Starting Core Unified Dashboards...$(NC)"
	@$(MAKE) start-unified-analytics
	@$(MAKE) start-unified-trading
	@$(MAKE) start-unified-news
	@echo "$(GREEN)✅ Core unified dashboards started!$(NC)"

start-unified-analytics: ## Start Unified Analytics Dashboard
	@echo "$(GREEN)📊 Starting Unified Analytics Dashboard (11115)...$(NC)"
	@kubectl port-forward svc/unified-analytics-dashboard 11115:80 -n trading-system > /dev/null 2>&1 &

start-unified-trading: ## Start Unified Trading Dashboard
	@echo "$(GREEN)📈 Starting Unified Trading Dashboard (11114)...$(NC)"
	@kubectl port-forward svc/unified-trading-dashboard 11114:80 -n trading-system > /dev/null 2>&1 &

start-unified-news: ## Start Unified News Dashboard
	@echo "$(GREEN)📰 Starting Unified News Dashboard (11113)...$(NC)"
	@kubectl port-forward svc/unified-news-dashboard 11113:80 -n trading-system > /dev/null 2>&1 &

start-central-hub: ## Start Central Hub Dashboard
	@echo "$(GREEN)🏠 Starting Central Hub Dashboard (11080)...$(NC)"
	@kubectl port-forward svc/central-hub-dashboard 11080:80 -n trading-system > /dev/null 2>&1 &

start-performance: ## Start Performance Dashboard
	@echo "$(GREEN)📈 Starting Performance Dashboard (11000)...$(NC)"
	@kubectl port-forward svc/performance-dashboard 11000:80 -n trading-system > /dev/null 2>&1 &

start-health: ## Start Health Dashboard
	@echo "$(GREEN)🏥 Starting Health Dashboard (11002)...$(NC)"
	@kubectl port-forward svc/health-dashboard 11002:80 -n trading-system > /dev/null 2>&1 &

start-rss: ## Start RSS Dashboard
	@echo "$(GREEN)📰 Starting RSS Dashboard (11003)...$(NC)"
	@kubectl port-forward svc/rss-dashboard 11003:80 -n trading-system > /dev/null 2>&1 &

start-ai-stock: ## Start AI Stock Dashboard
	@echo "$(GREEN)🤖 Starting AI Stock Dashboard (11086)...$(NC)"
	@kubectl port-forward svc/ai-stock-dashboard 11086:80 -n trading-system > /dev/null 2>&1 &

# =====================================================================
# 📈 MONITORING SERVICES (11100-11199)
# =====================================================================

start-monitoring: ## Start monitoring services
	@echo "$(GREEN)📊 Starting Monitoring Services...$(NC)"
	@$(MAKE) start-grafana
	@$(MAKE) start-prometheus
	@echo "$(GREEN)✅ All monitoring services started!$(NC)"

start-grafana: ## Start Grafana monitoring
	@echo "$(GREEN)📊 Starting Grafana (11102)...$(NC)"
	@kubectl port-forward svc/grafana 11102:3000 -n trading-system > /dev/null 2>&1 &

start-prometheus: ## Start Prometheus metrics
	@echo "$(GREEN)📈 Starting Prometheus (11190)...$(NC)"
	@kubectl port-forward svc/prometheus 11190:9090 -n trading-system > /dev/null 2>&1 &

# =====================================================================
# 🔧 DATA SERVICES (11080-11099)
# =====================================================================

start-data-services: ## Start data processing services
	@echo "$(GREEN)🔧 Starting Data Services...$(NC)"
	@$(MAKE) start-analytics
	@$(MAKE) start-data-pipeline
	@echo "$(GREEN)✅ All data services started!$(NC)"

start-analytics: ## Start Analytics Service
	@echo "$(GREEN)📊 Starting Analytics Service (11085)...$(NC)"
	@kubectl port-forward svc/analytics-service 11085:80 -n trading-system > /dev/null 2>&1 &

start-data-pipeline: ## Start Data Pipeline
	@echo "$(GREEN)🔄 Starting Data Pipeline (11087)...$(NC)"
	@kubectl port-forward svc/data-pipeline-dashboard 11087:80 -n trading-system > /dev/null 2>&1 &

# =====================================================================
# 📈 TRADING SERVICES (11090-11099)
# =====================================================================

start-trading-services: ## Start trading services
	@echo "$(GREEN)📈 Starting Trading Services...$(NC)"
	@$(MAKE) start-trading-ultra
	@$(MAKE) start-market-data
	@$(MAKE) start-backtest
	@$(MAKE) start-backtest-request
	@echo "$(GREEN)✅ All trading services started!$(NC)"

start-trading-ultra: ## Start Trading Ultra Service
	@echo "$(GREEN)📈 Starting Trading Ultra Service (11099)...$(NC)"
	@kubectl port-forward svc/trading-ultra-service 11099:80 -n trading-system > /dev/null 2>&1 &

start-market-data: ## Start Market Data Service
	@echo "$(GREEN)📊 Starting Market Data Service (11084)...$(NC)"
	@kubectl port-forward svc/market-data-service 11084:80 -n trading-system > /dev/null 2>&1 &

start-backtest: ## Start Backtest API
	@echo "$(GREEN)🧪 Starting Backtest API (11101)...$(NC)"
	@kubectl port-forward svc/backtest-api 11101:10001 -n trading-system > /dev/null 2>&1 &

start-backtest-request: ## Start Backtest Request Service
	@echo "$(GREEN)🧪 Starting Backtest Request Service (11100)...$(NC)"
	@kubectl port-forward svc/backtest-request-service 11100:80 -n trading-system > /dev/null 2>&1 &

# =====================================================================
# 🤖 AI SERVICES (11110-11119)
# =====================================================================

start-ai-services: ## Start AI/ML services
	@echo "$(GREEN)🤖 Starting AI Services...$(NC)"
	@$(MAKE) start-ollama
	@$(MAKE) start-llm-proxy
	@echo "$(GREEN)✅ All AI services started!$(NC)"

start-ollama: ## Start Ollama LLM
	@echo "$(GREEN)🤖 Starting Ollama LLM (11110)...$(NC)"
	@kubectl port-forward svc/ollama 11110:11434 -n trading-system > /dev/null 2>&1 &

start-llm-proxy: ## Start LLM Proxy
	@echo "$(GREEN)🔗 Starting LLM Proxy (11111)...$(NC)"
	@kubectl port-forward svc/llm-proxy 11111:80 -n trading-system > /dev/null 2>&1 &

# =====================================================================
# 🗄️ DATABASE SERVICES (11300-11399)
# =====================================================================

start-databases: ## Start database services
	@echo "$(GREEN)🗄️ Starting Database Services...$(NC)"
	@$(MAKE) start-timescaledb
	@$(MAKE) start-postgres
	@$(MAKE) start-redis
	@$(MAKE) start-rabbitmq
	@echo "$(GREEN)✅ All database services started!$(NC)"

start-timescaledb: ## Start TimescaleDB
	@echo "$(GREEN)🗄️ Starting TimescaleDB (11300)...$(NC)"
	@kubectl port-forward svc/timescaledb 11300:5432 -n trading-system > /dev/null 2>&1 &

start-postgres: ## Start PostgreSQL
	@echo "$(GREEN)🗄️ Starting PostgreSQL (11301)...$(NC)"
	@kubectl port-forward svc/postgres-vector-storage 11301:5432 -n trading-system > /dev/null 2>&1 &

start-redis: ## Start Redis
	@echo "$(GREEN)🗄️ Starting Redis (11379)...$(NC)"
	@kubectl port-forward svc/redis 11379:6379 -n trading-system > /dev/null 2>&1 &

start-rabbitmq: ## Start RabbitMQ
	@echo "$(GREEN)🐰 Starting RabbitMQ (11380)...$(NC)"
	@kubectl port-forward svc/rabbitmq 11380:5672 -n trading-system > /dev/null 2>&1 &

# =====================================================================
# 📋 SERVICE URLS
# =====================================================================

urls: ## Show all service URLs
	@echo "$(GREEN)🌐 Trading System Service URLs$(NC)"
	@echo "$(YELLOW)============================$(NC)"
	@echo ""
	@echo "$(BLUE)📊 Dashboards:$(NC)"
	@echo "  • Unified Analytics: http://localhost:11115/"
	@echo "  • Unified Trading: http://localhost:11114/"
	@echo "  • Unified News: http://localhost:11113/"
	@echo "  • Central Hub: http://localhost:11080/"
	@echo "  • Performance: http://localhost:11000/"
	@echo "  • Health: http://localhost:11002/"
	@echo "  • RSS: http://localhost:11003/"
	@echo "  • AI Stock: http://localhost:11086/"
	@echo ""
	@echo "$(BLUE)📈 Monitoring:$(NC)"
	@echo "  • Grafana: http://localhost:11102/"
	@echo "  • Prometheus: http://localhost:11190/"
	@echo ""
	@echo "$(BLUE)🔧 Services:$(NC)"
	@echo "  • Analytics: http://localhost:11085/"
	@echo "  • Data Pipeline: http://localhost:11087/"
	@echo "  • Trading Ultra: http://localhost:11099/"
	@echo "  • Market Data: http://localhost:11084/"
	@echo "  • Backtest API: http://localhost:11101/"
	@echo "  • Backtest Request: http://localhost:11100/"
	@echo ""
	@echo "$(BLUE)🤖 AI Services:$(NC)"
	@echo "  • Ollama: http://localhost:11110/"
	@echo "  • LLM Proxy: http://localhost:11111/"
	@echo ""
	@echo "$(BLUE)🗄️ Databases:$(NC)"
	@echo "  • TimescaleDB: localhost:11300"
	@echo "  • PostgreSQL: localhost:11301"
	@echo "  • Redis: localhost:11379"
	@echo "  • RabbitMQ: localhost:11380"

# Default target
.DEFAULT_GOAL := help
