# Simple Collaboration Makefile
# For 2-person development team

# =====================================================================
# NOTE: System Startup Tips
#
# For resource-constrained environments (e.g., laptops, dev VMs):
#   👉 Run: make deploy-vectorization-constrained
#   - Deploys all services with 1 pod each
#   - Starts basic port forwarding for dashboards
#   - Suitable for most development and testing
#
# For non-constrained environments (e.g., Mac Mini, servers):
#   👉 Run: make deploy-and-start
#   - Deploys all services (2 pods each)
#   - Starts comprehensive port watcher (monitors 30+ services)
#   - Best for full system testing and monitoring
#
# See also: make constrained-help and make deploy-help for more options
# =====================================================================

# =====================================================================
# 🚀 EASY STARTUP PROCESSES
# =====================================================================
deploy-vectorization-constrained: ## Easy startup for resource-constrained environments (Vectorization Service)
	@echo "$(GREEN)🚀 Starting Easy Startup Process for Resource-Constrained Environment$(NC)"
	@echo "$(YELLOW)===============================================================$(NC)"
	@echo ""
	@echo "$(BLUE)📋 What this does:$(NC)"
	@echo "  • Deploys Background Vectorization Service (basic deployment)"
	@echo "  • Sets up port forwarding for dashboards"
	@echo "  • Optimized for laptops and dev VMs"
	@echo ""
	@echo "$(GREEN)🔄 Starting deployment...$(NC)"
	
	# Check if namespace exists, create if not
	@echo "$(BLUE)🔍 Checking namespace...$(NC)"
	@kubectl get namespace trading-system > /dev/null 2>&1 || kubectl create namespace trading-system
	@echo "$(GREEN)✅ Namespace ready$(NC)"
	
	# Ensure all services are scaled appropriately for resource-constrained environments
	@echo "$(BLUE)⚖️  Scaling services for resource-constrained environment...$(NC)"
	@echo "$(YELLOW)💡 Setting all services to 1 pod each for efficiency$(NC)"
	@kubectl scale deployment --all --replicas=1 -n trading-system || true
	@echo "$(GREEN)✅ Services scaled appropriately$(NC)"
	
	# Deploy Background Vectorization Service (basic version)
	@echo "$(BLUE)📦 Deploying Background Vectorization Service...$(NC)"
	@cd services/background-vectorization-service && \
		docker build -t background-vectorization-service:latest . && \
		docker tag background-vectorization-service:latest localhost:32000/background-vectorization-service:latest && \
		docker push localhost:32000/background-vectorization-service:latest
	@kubectl apply -f services/background-vectorization-service/k8s-deployment-fixed.yaml
	@echo "$(GREEN)✅ Vectorization service deployed$(NC)"
	
	# Wait for service to be ready
	@echo "$(BLUE)⏳ Waiting for vectorization service to be ready...$(NC)"
	@kubectl wait --for=condition=available --timeout=300s deployment/background-vectorization-service -n trading-system || true
	@echo "$(GREEN)✅ Vectorization service ready$(NC)"
	
	# Start port forwarding for vectorization service
	@echo "$(BLUE)🌐 Starting port forwarding...$(NC)"
	@echo "$(YELLOW)💡 Starting port forwarding in background...$(NC)"
	@kubectl port-forward service/background-vectorization-service 11116:8080 -n trading-system > /dev/null 2>&1 &
	@echo "$(GREEN)✅ Vectorization service port forward started$(NC)"
	
	# Start port forwarding for other dashboards
	@echo "$(BLUE)🔍 Starting dashboard port forwards...$(NC)"
	@kubectl port-forward service/unified-analytics-dashboard 11114:80 -n trading-system > /dev/null 2>&1 &
	@kubectl port-forward service/unified-trading-dashboard 11115:80 -n trading-system > /dev/null 2>&1 &
	@kubectl port-forward service/unified-news-dashboard 11113:80 -n trading-system > /dev/null 2>&1 &
	@echo "$(GREEN)✅ All dashboard port forwards started$(NC)"
	
	# Show status
	@echo "$(GREEN)🎯 Easy Startup Complete!$(NC)"
	@echo "$(YELLOW)========================$(NC)"
	@echo "$(BLUE)📊 Service Status:$(NC)"
	@kubectl get pods -n trading-system -l app=background-vectorization-service
	@echo ""
	@echo "$(BLUE)🌐 Service URLs:$(NC)"
	@echo "  • Vectorization Service: http://localhost:11116/"
	@if kubectl get service unified-analytics-dashboard -n trading-system > /dev/null 2>&1; then \
		echo "  • Analytics Dashboard: http://localhost:11114/"; \
	fi
	@if kubectl get service unified-trading-dashboard -n trading-system > /dev/null 2>&1; then \
		echo "  • Trading Dashboard: http://localhost:11115/"; \
	fi
	@if kubectl get service unified-news-dashboard -n trading-system > /dev/null 2>&1; then \
		echo "  • News Dashboard: http://localhost:11113/"; \
	fi
	@echo ""
	@echo "$(GREEN)💡 Next Steps:$(NC)"
	@echo "  • Check service health: kubectl get pods -n trading-system"
	@echo "  • Test vectorization: curl http://localhost:11116/health"
	@echo "  • Monitor logs: kubectl logs -f deployment/background-vectorization-service -n trading-system"
	@echo ""
	@echo "$(YELLOW)🚀 Background Vectorization Service is now part of your easy startup!$(NC)"

deploy-vc: deploy-vectorization-constrained ## Alias for deploy-vectorization-constrained

scale-for-constrained: ## Scale all services to 1 pod each for resource-constrained environments
	@echo "$(GREEN)⚖️  Scaling Services for Resource-Constrained Environment$(NC)"
	@echo "$(YELLOW)====================================================$(NC)"
	@echo ""
	@echo "$(BLUE)📋 What this does:$(NC)"
	@echo "  • Scales all services to 1 pod each (efficient for laptops/dev VMs)"
	@echo "  • Frees up CPU and memory resources"
	@echo "  • Prevents resource exhaustion and pod scheduling failures"
	@echo "  • Optimized for development and testing"
	@echo ""
	@echo "$(GREEN)🔄 Starting scaling process...$(NC)"
	
	# Scale all deployments to 1 replica
	@echo "$(BLUE)📦 Scaling all services to 1 pod each...$(NC)"
	@kubectl scale deployment --all --replicas=1 -n trading-system || true
	@echo "$(GREEN)✅ All services scaled to 1 pod each$(NC)"
	
	# Wait for scaling to complete
	@echo "$(BLUE)⏳ Waiting for scaling to complete...$(NC)"
	@kubectl wait --for=condition=available --timeout=300s deployment --all -n trading-system || true
	@echo "$(GREEN)✅ Scaling complete$(NC)"
	
	# Show current status
	@echo "$(GREEN)🎯 Scaling Complete!$(NC)"
	@echo "$(YELLOW)==================$(NC)"
	@echo "$(BLUE)📊 Current Pod Status:$(NC)"
	@kubectl get pods -n trading-system --no-headers | awk '{print $1}' | sed 's/-[a-z0-9]*-[a-z0-9]*$//' | sort | uniq -c | sort -nr | head -15
	@echo ""
	@echo "$(GREEN)💡 Next Steps:$(NC)"
	@echo "  • Check resource usage: kubectl top nodes"
	@echo "  • Monitor pods: kubectl get pods -n trading-system"
	@echo "  • Deploy vectorization service: make -f Makefile.simple deploy-vectorization-constrained"
	@echo ""
	@echo "$(YELLOW)🚀 System is now optimized for resource-constrained environments!$(NC)"

deploy-and-start: ## Full deployment for non-constrained environments
	@echo "$(GREEN)🚀 Starting Full Deployment Process$(NC)"
	@echo "$(YELLOW)==================================$(NC)"
	@echo ""
	@echo "$(BLUE)📋 What this does:$(NC)"
	@echo "  • Deploys all services (2 pods each for redundancy)"
	@echo "  • Starts comprehensive port watcher (monitors 30+ services)"
	@echo "  • Best for full system testing and monitoring"
	@echo "  • Suitable for Mac Mini, servers, and high-resource environments"
	@echo ""
	@echo "$(GREEN)🔄 Starting deployment...$(NC)"
	
	# Deploy Background Vectorization Service (production version)
	@echo "$(BLUE)📦 Deploying Background Vectorization Service (Production)...$(NC)"
	@cd services/background-vectorization-service && \
		docker build -t background-vectorization-service:latest . && \
		docker tag background-vectorization-service:latest localhost:32000/background-vectorization-service:latest && \
		docker push localhost:32000/background-vectorization-service:latest
	@kubectl apply -f services/background-vectorization-service/k8s/background-vectorization-service-production.yaml
	@kubectl apply -f services/background-vectorization-service/k8s/vectorization-cronjobs.yaml
	@echo "$(GREEN)✅ Production vectorization service deployed$(NC)"
	
	# Start comprehensive port watcher
	@echo "$(BLUE)👀 Starting comprehensive port watcher...$(NC)"
	@echo "$(YELLOW)💡 This will monitor 30+ services...$(NC)"
	# Add your comprehensive port watcher command here
	@echo "$(GREEN)✅ Port watcher started$(NC)"
	
	# Show status
	@echo "$(GREEN)🎯 Full Deployment Complete!$(NC)"
	@echo "$(YELLOW)==========================$(NC)"
	@echo "$(BLUE)📊 Service Status:$(NC)"
	@kubectl get pods -n trading-system -l app=background-vectorization-service
	@kubectl get cronjobs -n trading-system -l app=vectorization
	@echo ""
	@echo "$(GREEN)💡 Next Steps:$(NC)"
	@echo "  • Monitor scaling: kubectl get hpa -n trading-system"
	@echo "  • Check cronjobs: kubectl get cronjobs -n trading-system"
	@echo "  • Test webhooks: curl http://localhost:11116/api/integration/webhooks/status"
	@echo ""
	@echo "$(YELLOW)🚀 Production Background Vectorization Service is now running!$(NC)"

constrained-help: ## Show help for resource-constrained environments
	@echo "$(GREEN)💡 Resource-Constrained Environment Help$(NC)"
	@echo "$(YELLOW)========================================$(NC)"
	@echo ""
	@echo "$(BLUE)🚀 Quick Start:$(NC)"
	@echo "  make deploy-vectorization-constrained"
	@echo ""
	@echo "$(BLUE)📋 What it includes:$(NC)"
	@echo "  • Background Vectorization Service (basic deployment)"
	@echo "  • Essential trading system services"
	@echo "  • Port forwarding for dashboards"
	@echo "  • Resource-optimized configuration"
	@echo ""
	@echo "$(BLUE)💻 Suitable for:$(NC)"
	@echo "  • Laptops and development VMs"
	@echo "  • Limited CPU/memory environments"
	@echo "  • Development and testing"
	@echo ""
	@echo "$(GREEN)✅ No need to remember separate commands!$(NC)"

deploy-help: ## Show help for deployment options
	@echo "$(GREEN)🚀 Deployment Options Help$(NC)"
	@echo "$(YELLOW)==========================$(NC)"
	@echo ""
	@echo "$(BLUE)Resource-Constrained (Laptops, Dev VMs):$(NC)"
	@echo "  make deploy-vectorization-constrained"
	@echo "  • 1 pod per service for efficiency"
	@echo "  • Basic vectorization service"
	@echo "  • Essential port forwarding"
	@echo ""
	@echo "$(BLUE)Full Production (Mac Mini, Servers):$(NC)"
	@echo "  make deploy-and-start"
	@echo "  • 2+ pods per service for redundancy"
	@echo "  • Production vectorization service with scaling"
	@echo "  • Comprehensive monitoring"
	@echo ""
	@echo "$(GREEN)💡 Both include Background Vectorization Service automatically!$(NC)"

