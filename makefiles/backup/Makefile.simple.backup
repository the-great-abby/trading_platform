# =====================================================================
# Making AI a first-class citizen in the development process

ai-review: ## AI-assisted code review with context from all rules
	@echo "$(GREEN)🤖 AI Code Review - Making AI a First-Class Citizen$(NC)"
	@echo "$(YELLOW)==================================================$(NC)"
	@echo ""
	@echo "$(GREEN)🔄 Starting AI code review...$(NC)"
	@echo "$(YELLOW)💡 AI will analyze your current working directory and suggest improvements$(NC)"
	@echo "$(BLUE)📚 AI will reference: Core Rules + AI Development Assistant + Domain Rules$(NC)"
	@echo ""
	@if [ -f "scripts/ai_code_review.py" ]; then \
		python3 scripts/ai_code_review.py --path . --rules all --ollama-url http://localhost:12001 --callback-port 11999; \
	else \
		echo "$(RED)❌ AI Code Review script not found. Creating it now...$(NC)"; \
		echo "$(YELLOW)💡 Run 'make ai-review' again after the script is created.$(NC)"; \
	fi

