.PHONY: help status sync critical debug progress learning blocker startup llm-fix-resource-fix k8s-learn k8s-learn-preview k8s-rag-chat k8s-rag-chat-deploy vectorization-progress secret-key-fix earnings-progress deploy-vectorization-constrained deploy-vc scale-for-constrained deploy-and-start constrained-help deploy-help ai-review ai-refactor ai-test ai-docs ai-optimize ai-security ai-setup ai-debug ai-workflow ai-help

# Colors for output
GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

help: ## Show this help message
	@echo "$(GREEN)🚀 Trading Platform Development Commands$(NC)"
	@echo "$(YELLOW)==========================================$(NC)"
	@echo ""
	@echo "$(GREEN)Project Status:$(NC)"
	@echo "  status         - Show current project status and progress"
	@echo "  sync           - Quick team sync with current status"
	@echo "  critical       - Show critical path and testing priorities"
	@echo "  progress       - Show detailed progress on all areas"
	@echo "  learning       - Show learning progress and next steps"
	@echo "  blocker        - Report and track blockers"
	@echo ""
	@echo "$(GREEN)Development:$(NC)"
	@echo "  startup        - Quick session startup"
	@echo "  debug          - Show debug information and logs"
	@echo ""
	@echo "$(GREEN)Infrastructure:$(NC)"
	@echo "  llm-fix-resource-fix - Fix LLM resource constraints"
	@echo "  k8s-learn      - Learn Kubernetes with interactive examples"
	@echo "  k8s-learn-preview - Preview Kubernetes learning content"
	@echo "  k8s-rag-chat   - Chat with Kubernetes knowledge base"
	@echo "  k8s-rag-chat-deploy - Deploy Kubernetes RAG chat system"
	@echo ""
	@echo "$(GREEN)Data & Analytics:$(NC)"
	@echo "  vectorization-progress - Show vectorization progress"
	@echo "  secret-key-fix - Fix secret key issues"
	@echo "  earnings-progress - Show earnings data progress"
	@echo ""
	@echo "$(GREEN)Deployment:$(NC)"
	@echo "  deploy-vectorization-constrained - Deploy with resource constraints"
	@echo "  deploy-vc      - Deploy vectorization service"
	@echo "  scale-for-constrained - Scale services for constraints"
	@echo "  deploy-and-start - Deploy and start services"
	@echo "  constrained-help - Help for constrained deployments"
	@echo "  deploy-help    - General deployment help"
	@echo ""
	@echo "$(GREEN)AI-Assisted Development:$(NC)"
	@echo "  ai-review      - AI code review with context from all rules"
	@echo "  ai-refactor    - AI-assisted refactoring using style rules"
	@echo "  ai-test        - AI test generation with comprehensive coverage"
	@echo "  ai-docs        - AI documentation updates and improvements"
	@echo "  ai-optimize    - AI performance optimization suggestions"
	@echo "  ai-security    - AI security scanning and best practices"
	@echo "  ai-setup       - AI-assisted new service setup with all relevant rules"
	@echo "  ai-debug       - AI-assisted debugging with comprehensive analysis"
	@echo "  ai-workflow    - AI-assisted development workflow optimization"
	@echo "  ai-help        - Show all AI-assisted development commands"
	@echo ""
	@echo "$(BLUE)💡 Use 'make <target>' to run any command$(NC)"
	@echo "$(BLUE)💡 Use 'make -n <target>' to see what a command would do$(NC)"

# =====================================================================
