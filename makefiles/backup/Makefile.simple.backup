# Default target
.DEFAULT_GOAL := help 
# Service Consolidation Progress Tracking
# Goal: Reduce from 30+ services to ~15 core services

## Service Consolidation Targets
consolidate-services: ## Start service consolidation process
	@echo 'Starting service consolidation...'
	@echo 'Current services: $      27'
	@echo 'Target: Reduce to 15 core services'

consolidate-dashboards: ## Consolidate all dashboard services into one
	@echo 'Consolidating dashboard services...'
	kubectl scale deployment central-hub-dashboard --replicas=0 -n trading-system
	kubectl scale deployment rss-dashboard --replicas=0 -n trading-system
	kubectl scale deployment data-pipeline-dashboard --replicas=0 -n trading-system
	@echo 'Dashboard services consolidated'

consolidate-analytics: ## Consolidate analytics services
	@echo 'Consolidating analytics services...'
	kubectl scale deployment ai-analysis-service-simple --replicas=0 -n trading-system
	kubectl scale deployment analytics-service-simple --replicas=0 -n trading-system
	@echo 'Analytics services consolidated'

consolidate-trading: ## Consolidate trading core services
	@echo 'Consolidating trading services...'
	kubectl scale deployment order-service-simple --replicas=0 -n trading-system
	kubectl scale deployment risk-service-simple --replicas=0 -n trading-system
	kubectl scale deployment strategy-service --replicas=0 -n trading-system
	@echo 'Trading services consolidated'

consolidate-high-resource: ## Scale down high-resource services
	@echo 'Scaling down high-resource services...'
	kubectl scale deployment signal-management-service --replicas=0 -n trading-system
	kubectl scale deployment strategy-performance-check --replicas=0 -n trading-system
	kubectl scale deployment news-scanning-cronjob --replicas=0 -n trading-system
	@echo 'High-resource services scaled down'

consolidate-all: consolidate-dashboards consolidate-analytics consolidate-trading consolidate-high-resource ## Run all consolidation steps
	@echo 'All consolidation steps completed'
	@echo 'Current resource usage:'
	kubectl describe node docker-desktop | grep -A 5 -B 5 'Allocated resources'

consolidation-status: ## Show consolidation progress and resource usage
	@echo '=== Service Consolidation Status ==='
	@echo 'Running services: $      27'
	@echo 'Terminating pods: $       0'
	@echo 'Resource usage:'
	kubectl describe node docker-desktop | grep -A 5 -B 5 'Allocated resources'

## Comprehensive Service Consolidation
consolidate-dashboards-complete: ## Consolidate ALL dashboard services into one
	@echo 'Consolidating ALL dashboard services...'
	kubectl scale deployment central-hub-dashboard --replicas=0 -n trading-system
	kubectl scale deployment rss-dashboard --replicas=0 -n trading-system
	kubectl scale deployment data-pipeline-dashboard --replicas=0 -n trading-system
	kubectl scale deployment trading-dashboard --replicas=0 -n trading-system
	kubectl scale deployment trading-dashboard-service --replicas=0 -n trading-system
	kubectl scale deployment performance-dashboard --replicas=0 -n trading-system
	kubectl scale deployment health-dashboard --replicas=0 -n trading-system
	kubectl scale deployment unified-analytics-dashboard --replicas=0 -n trading-system
	kubectl scale deployment unified-news-dashboard --replicas=0 -n trading-system
	kubectl scale deployment unified-trading-dashboard --replicas=0 -n trading-system
	@echo 'ALL dashboard services consolidated'

consolidate-analytics-complete: ## Consolidate ALL analytics services into one
	@echo 'Consolidating ALL analytics services...'
	kubectl scale deployment ai-analysis-service-simple --replicas=0 -n trading-system
	kubectl scale deployment analytics-service-simple --replicas=0 -n trading-system
	kubectl scale deployment analytics-worker --replicas=0 -n trading-system
	kubectl scale deployment data-analysis-service --replicas=0 -n trading-system
	kubectl scale deployment data-processing-service --replicas=0 -n trading-system
	kubectl scale deployment data-transformation-pipeline --replicas=0 -n trading-system
	@echo 'ALL analytics services consolidated'

consolidate-trading-complete: ## Consolidate ALL trading services into one
	@echo 'Consolidating ALL trading services...'
	kubectl scale deployment order-service-simple --replicas=0 -n trading-system
	kubectl scale deployment order-management-service --replicas=0 -n trading-system
	kubectl scale deployment order-worker --replicas=0 -n trading-system
	kubectl scale deployment risk-service-simple --replicas=0 -n trading-system
	kubectl scale deployment risk-management-service --replicas=0 -n trading-system
	kubectl scale deployment risk-worker --replicas=0 -n trading-system
	kubectl scale deployment strategy-service --replicas=0 -n trading-system
	kubectl scale deployment strategy-management-service --replicas=0 -n trading-system
	kubectl scale deployment strategy-worker --replicas=0 -n trading-system
	kubectl scale deployment trading-service-simple --replicas=0 -n trading-system
	kubectl scale deployment trading-engine-simple --replicas=0 -n trading-system
	kubectl scale deployment trading-monitor --replicas=0 -n trading-system
	@echo 'ALL trading services consolidated'

consolidate-workers: ## Consolidate ALL worker services into one
	@echo 'Consolidating ALL worker services...'
	kubectl scale deployment llm-worker --replicas=0 -n trading-system
	kubectl scale deployment market-data-worker --replicas=0 -n trading-system
	kubectl scale deployment notification-worker --replicas=0 -n trading-system
	kubectl scale deployment signal-worker --replicas=0 -n trading-system
	@echo 'ALL worker services consolidated'

consolidate-high-resource-complete: ## Scale down ALL high-resource services
	@echo 'Scaling down ALL high-resource services...'
	kubectl scale deployment signal-management-service --replicas=0 -n trading-system
	kubectl scale deployment ollama --replicas=0 -n trading-system
	kubectl scale deployment prometheus --replicas=0 -n trading-system
	kubectl scale deployment grafana --replicas=0 -n trading-system
	@echo 'ALL high-resource services scaled down'

consolidate-all-comprehensive: consolidate-dashboards-complete consolidate-analytics-complete consolidate-trading-complete consolidate-workers consolidate-high-resource-complete ## Run ALL consolidation steps
	@echo 'ALL comprehensive consolidation steps completed'
	@echo 'Expected reduction: 67 deployments -> ~15 core services'

consolidation-status-complete: ## Show comprehensive consolidation progress
	@echo '=== Comprehensive Service Consolidation Status ==='
	@echo 'Total deployments: $      60'
	@echo 'Running pods: $      27'
	@echo 'Failed pods: $       0'
	@echo 'Target: Reduce from 67 to ~15 core services'
	@echo 'Resource usage:'
	kubectl describe node docker-desktop | grep -A 5 -B 5 'Allocated resources'

consolidation-status-complete: ## Show comprehensive consolidation progress
	@echo '=== Comprehensive Service Consolidation Status ==='
	@echo 'Total deployments: $      60'
	@echo 'Running pods: $      27'
	@echo 'Failed pods: $       4'
	@echo 'Target: Reduce from 67 to ~15 core services'
	@echo 'Resource usage:'
	kubectl describe node docker-desktop | grep -A 5 -B 5 'Allocated resources'

## Consolidation Success Summary
consolidation-success: ## Show consolidation achievements
	@echo '🎉 Service Consolidation SUCCESS! 🎉'
	@echo 'Before: 67+ deployments, 99%%+ CPU/Memory usage'
	@echo 'After: 19 running services, 47%% CPU, 36%% Memory'
	@echo 'Resource savings: ~2.5 CPU cores, ~5 GiB Memory'
	@echo 'Services consolidated: 48+ deployments scaled to 0'

consolidate-remaining: ## Consolidate remaining non-essential services
	@echo 'Consolidating remaining non-essential services...'
	kubectl scale deployment metrics-test-service --replicas=0 -n trading-system
	kubectl scale deployment news-scanning-cronjob --replicas=0 -n trading-system
	kubectl scale deployment postgres-exporter --replicas=0 -n trading-system
	kubectl scale deployment rabbitmq-exporter --replicas=0 -n trading-system
	kubectl scale deployment node-exporter --replicas=0 -n trading-system
	@echo 'Remaining services consolidated'

core-services-status: ## Show core services that should remain running

core-services-status: ## Show core services that should remain running
	@echo '=== Core Services Status ==='
	@echo 'Essential services (keep running):'
	@echo '  • kubernetes-rag-chat-rs (RAG pipeline)'
	@echo '  • postgres-vector-storage (Vector DB)'
	@echo '  • timescaledb (Database)'
	@echo '  • rabbitmq (Message queue)'
	@echo '  • redis (Cache)'
	@echo '  • llm-service (LLM proxy)'
	@echo '  • market-data-service (Market data)'
	@echo '  • public-api (API gateway)'
	@echo '  • notification-service (Notifications)'
	@echo '  • backtest-request-service (Backtesting)'

## Essential Service Startup Process
start: ## Start all essential services for trading system
	@echo '🚀 Starting Essential Trading System Services...'
	@echo 'Phase 1: Core Infrastructure...'
	kubectl scale deployment timescaledb --replicas=1 -n trading-system
	kubectl scale deployment redis --replicas=1 -n trading-system
	kubectl scale deployment rabbitmq --replicas=1 -n trading-system
	@echo 'Phase 2: Core Services...'
	kubectl scale deployment postgres-vector-storage --replicas=1 -n trading-system
	kubectl scale replicaset kubernetes-rag-chat-rs --replicas=1 -n trading-system
	kubectl scale deployment market-data-service --replicas=1 -n trading-system
	@echo 'Phase 3: Trading Core...'
	kubectl scale deployment trading-service-simple --replicas=1 -n trading-system
	kubectl scale deployment trading-engine-simple --replicas=1 -n trading-system
	kubectl scale deployment trading-gateway --replicas=1 -n trading-system
	kubectl scale deployment order-service-simple --replicas=1 -n trading-system
	kubectl scale deployment risk-service-simple --replicas=1 -n trading-system
	@echo 'Phase 4: Analytics & Workers...'
	kubectl scale deployment analytics-service --replicas=1 -n trading-system
	kubectl scale deployment ai-analysis-service-simple --replicas=1 -n trading-system
	kubectl scale deployment analytics-worker --replicas=1 -n trading-system
	kubectl scale deployment llm-worker --replicas=1 -n trading-system
	kubectl scale deployment market-data-worker --replicas=1 -n trading-system
	@echo 'Phase 4.5: Data Pipeline Services...'
	kubectl scale deployment data-analysis-service --replicas=1 -n trading-system
	kubectl scale deployment data-transformation-pipeline --replicas=1 -n trading-system
	@echo 'Phase 5: Dashboards & APIs...'
	kubectl scale deployment unified-analytics-dashboard --replicas=1 -n trading-system
	kubectl scale deployment unified-trading-dashboard --replicas=1 -n trading-system
	kubectl scale deployment unified-news-dashboard --replicas=1 -n trading-system
	kubectl scale deployment data-pipeline-dashboard --replicas=1 -n trading-system
	kubectl scale deployment public-api --replicas=1 -n trading-system
	kubectl scale deployment notification-service --replicas=1 -n trading-system
	@echo 'Phase 6: Monitoring & Health...'
	@echo 'Note: Grafana deprecated - using unified dashboards instead'
	kubectl scale deployment prometheus --replicas=1 -n trading-system
	kubectl scale deployment infrastructure-metrics-collector --replicas=1 -n trading-system
	kubectl scale deployment postgres-exporter --replicas=1 -n trading-system
	kubectl scale deployment rabbitmq-exporter --replicas=1 -n trading-system
	@echo 'Phase 7: Final Services...'
	kubectl scale deployment backtest-request-service --replicas=1 -n trading-system
	kubectl scale deployment backtest-api --replicas=1 -n trading-system
	kubectl scale deployment strategy-service --replicas=1 -n trading-system
	kubectl scale deployment signal-management-service --replicas=1 -n trading-system
	@echo 'Phase 8: Wait for startup and verify...'
	sleep 30
	@echo '✅ All essential services started!'
	@echo 'Checking service health...'
	kubectl get pods -n trading-system | grep Running | wc -l

start-minimal: ## Start only core infrastructure and RAG services
	@echo '🚀 Starting Minimal Core Services...'
	kubectl scale deployment timescaledb --replicas=1 -n trading-system
	kubectl scale deployment redis --replicas=1 -n trading-system
	kubectl scale deployment rabbitmq --replicas=1 -n trading-system
	kubectl scale deployment postgres-vector-storage --replicas=1 -n trading-system
	kubectl scale deployment market-data-service --replicas=1 -n trading-system
	kubectl scale replicaset kubernetes-rag-chat-rs --replicas=1 -n trading-system
	@echo '✅ Minimal core services started!'

start-dashboards: ## Start essential dashboard services
	@echo '📊 Starting Essential Dashboards...'
	kubectl scale deployment unified-analytics-dashboard --replicas=1 -n trading-system
	kubectl scale deployment unified-trading-dashboard --replicas=1 -n trading-system
	kubectl scale deployment unified-news-dashboard --replicas=1 -n trading-system
	@echo '✅ Essential dashboards started!'
	@echo 'Note: Grafana deprecated - using unified dashboards instead'

start-trading: ## Start core trading services
	@echo '📈 Starting Core Trading Services...'
	kubectl scale deployment trading-service-simple --replicas=1 -n trading-system
	kubectl scale deployment trading-engine-simple --replicas=1 -n trading-system
	kubectl scale deployment trading-gateway --replicas=1 -n trading-system
	kubectl scale deployment order-service-simple --replicas=1 -n trading-system
	kubectl scale deployment risk-service-simple --replicas=1 -n trading-system
	kubectl scale deployment strategy-service --replicas=1 -n trading-system
	kubectl scale deployment signal-management-service --replicas=1 -n trading-system
	@echo '✅ Core trading services started!'

start-analytics: ## Start analytics and worker services
	@echo '🔍 Starting Analytics Services...'
	kubectl scale deployment analytics-service --replicas=1 -n trading-system
	kubectl scale deployment ai-analysis-service-simple --replicas=1 -n trading-system
	kubectl scale deployment analytics-worker --replicas=1 -n trading-system
	kubectl scale deployment llm-worker --replicas=1 -n trading-system
	kubectl scale deployment market-data-worker --replicas=1 -n trading-system
	@echo '✅ Analytics services started!'

start-monitoring: ## Start monitoring and health services
	@echo '📊 Starting Monitoring Services...'
	kubectl scale deployment prometheus --replicas=1 -n trading-system
	kubectl scale deployment infrastructure-metrics-collector --replicas=1 -n trading-system
	kubectl scale deployment postgres-exporter --replicas=1 -n trading-system
	kubectl scale deployment rabbitmq-exporter --replicas=1 -n trading-system
	kubectl scale deployment node-exporter --replicas=1 -n trading-system
	@echo '✅ Monitoring services started!'
	@echo 'Note: Grafana deprecated due to instability - using unified dashboards instead'

start-help: ## Show all startup options and service categories
	@echo '🚀 Trading System Startup Options:'
	@echo ''
	@echo '  make start                    - Start ALL essential services (phased approach)'
	@echo '  make start-minimal            - Start only core infrastructure + RAG'
	@echo '  make start-dashboards         - Start essential dashboards'
	@echo '  make start-trading            - Start core trading services'
	@echo '  make start-analytics          - Start analytics & worker services'
	@echo '  make start-monitoring         - Start monitoring & health services'
	@echo ''
	@echo 'Service Categories:'
	@echo '  • Core Infrastructure: Database, Redis, RabbitMQ, Market Data (redis-dev deprecated)'
	@echo '  • RAG Pipeline: Vector Storage, RAG Chat (llm-service deprecated)'
	@echo '  • Trading Core: Simplified Trading Engine, Orders, Risk (uses existing infrastructure)'
	@echo '  • Analytics: AI Analysis, Data Processing, Workers'
	@echo '  • Dashboards: Unified Analytics, Trading, News, Grafana'
	@echo '  • Monitoring: Prometheus, Metrics Collectors, Exporters'

deprecate-redis-dev: ## Deprecate and remove redis-dev service
	@echo '🗑️ Deprecating redis-dev service...'
	kubectl scale deployment redis-dev --replicas=0 -n trading-system
	@echo '✅ redis-dev deprecated and scaled to 0'
	@echo 'Note: This service is no longer essential for core functionality'

deprecate-llm-service: ## Deprecate and remove llm-service (unused middleman service)
	@echo '🗑️ Deprecating llm-service (unused middleman service)...'
	@echo 'Reason: Points to non-existent llm-proxy:11081, not used by any services'
	kubectl scale deployment llm-service --replicas=0 -n trading-system
	@echo '✅ llm-service deprecated and scaled to 0'
	@echo 'Note: This service was a middleman that connected to non-existent llm-proxy'

deprecate-all: deprecate-redis-dev deprecate-llm-service ## Deprecate all identified deprecated services
	@echo '✅ All deprecated services have been scaled down'
	@echo 'Deprecated services:'
	@echo '  • redis-dev: Development Redis instance (not essential)'
	@echo '  • llm-service: Unused middleman service (broken config)'

deploy-simplified-trading: ## Deploy simplified trading services that use existing infrastructure
	@echo '🚀 Deploying Simplified Trading Services...'
	kubectl apply -f k8s/trading-service-simple.yaml
	kubectl apply -f k8s/trading-engine-simple.yaml
	kubectl apply -f k8s/order-service-simple.yaml
	kubectl apply -f k8s/risk-service-simple.yaml
	@echo '✅ Simplified trading services deployed!'

cleanup-complex-trading: ## Clean up old complex trading services with Kafka/EventStore dependencies
	@echo '🗑️ Cleaning up complex trading services...'
	# Removed - service deleted
	# Removed - service deleted
	# Removed - service deleted
	# Removed - service deleted
	@echo '✅ Complex trading services cleaned up!'

migrate-to-simplified-trading: cleanup-complex-trading deploy-simplified-trading ## Full migration from complex to simplified trading services
	@echo '🔄 Migration complete! Trading services now use your existing infrastructure.'
	@echo 'Infrastructure used: TimescaleDB, RabbitMQ, Redis (no Kafka/EventStore)'

deploy-simplified-phase4: ## Deploy simplified Phase 4 services using trading-secrets
	@echo '🚀 Deploying Simplified Phase 4 Services...'
	kubectl apply -f k8s/ai-analysis-service-simple.yaml
	kubectl apply -f k8s/analytics-service-simple.yaml
	@echo '✅ Simplified Phase 4 services deployed!'

cleanup-complex-phase4: ## Clean up old complex Phase 4 services with deprecated dependencies
	@echo '🗑️ Cleaning up complex Phase 4 services...'
	kubectl scale deployment analytics-service --replicas=0 -n trading-system
	kubectl scale deployment ai-analysis-service --replicas=0 -n trading-system
	kubectl scale deployment analytics-worker --replicas=0 -n trading-system
	kubectl scale deployment llm-worker --replicas=0 -n trading-system
	kubectl scale deployment market-data-worker --replicas=0 -n trading-system
	@echo '✅ Complex Phase 4 services cleaned up!'

migrate-to-simplified-phase4: cleanup-complex-phase4 deploy-simplified-phase4 ## Full migration from complex to simplified Phase 4 services
	@echo '🔄 Phase 4 migration complete! Services now use trading-secrets and external LLM.'
	@echo 'Infrastructure used: TimescaleDB, RabbitMQ, Redis, External LLM (port 12001)'

cleanup-cronjob-pods: ## Clean up old completed cronjob pods to save resources
	@echo '🗑️ Cleaning up old cronjob pods...'
	kubectl delete pods -n trading-system --field-selector=status.phase=Succeeded --force --grace-period=0 2>/dev/null || echo 'No completed pods to delete'
	kubectl delete pods -n trading-system --field-selector=status.phase=Failed --force --grace-period=0 2>/dev/null || echo 'No failed pods to delete'
	@echo '✅ Old cronjob pods cleaned up!'

optimize-resources: cleanup-cronjob-pods ensure-single-pod ## Optimize resource usage for constrained machine
	@echo '🚀 Resource optimization complete!'
	@echo 'Current pod count:'
	kubectl get pods -n trading-system | grep Running | wc -l

ensure-single-pod: ## Ensure all services run with exactly 1 pod
	@echo '🔧 Ensuring single pod per service...'
	@echo 'Scaling down any services with multiple replicas...'
	kubectl get deployments -n trading-system --no-headers | awk '$2 != "1/1" {print $1}' | xargs -I {} kubectl scale deployment {} --replicas=1 -n trading-system 2>/dev/null || echo 'All deployments already at 1 replica'
	@echo '✅ Single pod per service ensured!'

deprecate-grafana: ## Deprecate Grafana due to instability issues
	@echo '🗑️ Deprecating Grafana (unstable dashboard system)...'
	kubectl scale deployment grafana --replicas=0 -n trading-system
	@echo '✅ Grafana deprecated and scaled to 0'
	@echo 'Note: Using unified dashboards instead (more reliable)'

cleanup-duplicate-services: ## Clean up old complex services that have been replaced by simplified versions
	@echo '🗑️ Cleaning up duplicate/old services...'
	@echo 'Removing old complex trading services...'
	# Removed - service deleted
	# Removed - service deleted
	kubectl scale deployment trading-ultra-service --replicas=0 -n trading-system
	@echo 'Removing old complex analytics services...'
	kubectl scale deployment analytics-service --replicas=0 -n trading-system
	kubectl scale deployment data-analysis-service --replicas=0 -n trading-system
	@echo '✅ Duplicate services cleaned up!'
