	@echo 'Target: Reduce from 67 to ~15 core services'
	@echo 'Resource usage:'
	kubectl describe node docker-desktop | grep -A 5 -B 5 'Allocated resources'

consolidation-success: ## Show consolidation achievements
	@echo '🎉 Service Consolidation SUCCESS! 🎉'
	@echo 'Before: 67+ deployments, 99%+ CPU/Memory usage'
	@echo 'After: 19 running services, 47% CPU, 36% Memory'
	@echo 'Resource savings: ~2.5 CPU cores, ~5 GiB Memory'
	@echo 'Services consolidated: 48+ deployments scaled to 0'

consolidate-remaining: ## Consolidate remaining non-essential services
	@echo 'Consolidating remaining non-essential services...'
	kubectl scale deployment metrics-test-service --replicas=0 -n trading-system
	kubectl scale deployment news-scanning-cronjob --replicas=0 -n trading-system
	kubectl scale deployment postgres-exporter --replicas=0 -n trading-system
	kubectl scale deployment rabbitmq-exporter --replicas=0 -n trading-system
	kubectl scale deployment node-exporter --replicas=0 -n trading-system
