# Testing Makefile
# Clean, organized testing commands

GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

.PHONY: help test-run test-unit test-integration test-e2e test-coverage test-clean test-status

test-help: ## Show testing help
	@echo "$(GREEN)🧪 Testing Commands$(NC)"
	@echo "$(YELLOW)==================$(NC)"
	@echo ""
	@echo "$(GREEN)Basic Operations:$(NC)"
	@echo "  test-run        - Run all tests"
	@echo "  test-unit       - Run unit tests"
	@echo "  test-integration - Run integration tests"
	@echo "  test-e2e        - Run end-to-end tests"
	@echo "  test-coverage   - Run tests with coverage"
	@echo "  test-clean      - Clean test artifacts"
	@echo "  test-status     - Show test status"
	@echo ""

test-run: ## Run all tests
	@echo "$(GREEN)🧪 Running All Tests...$(NC)"
	@echo "Running pytest..."
	pytest tests/ -v

test-unit: ## Run unit tests
	@echo "$(GREEN)🧪 Running Unit Tests...$(NC)"
	@echo "Running unit tests..."
	pytest tests/unit/ -v

test-integration: ## Run integration tests
	@echo "$(GREEN)🧪 Running Integration Tests...$(NC)"
	@echo "Running integration tests..."
	pytest tests/integration/ -v

test-e2e: ## Run end-to-end tests
	@echo "$(GREEN)🧪 Running End-to-End Tests...$(NC)"
	@echo "Running E2E tests..."
	pytest tests/e2e/ -v

test-coverage: ## Run tests with coverage
	@echo "$(GREEN)🧪 Running Tests with Coverage...$(NC)"
	@echo "Running tests with coverage..."
	pytest tests/ --cov=src --cov-report=html --cov-report=term

test-clean: ## Clean test artifacts
	@echo "$(YELLOW)🧹 Cleaning Test Artifacts...$(NC)"
	@echo "Cleaning test artifacts..."
	rm -rf htmlcov/
	rm -rf .coverage
	rm -rf .pytest_cache/
	@echo "✅ Test artifacts cleaned"

test-status: ## Show test status
	@echo "$(GREEN)📊 Test Status$(NC)"
	@echo "$(YELLOW)============$(NC)"
	@echo ""
	@echo "Test directories:"
	@ls tests/ 2>/dev/null || echo "No tests directory found"
	@echo ""
	@echo "Coverage report:"
	@ls htmlcov/ 2>/dev/null && echo "✅ Coverage report available" || echo "❌ No coverage report"
