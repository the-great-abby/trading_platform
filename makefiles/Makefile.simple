# Simple Commands Makefile
# Quick status, sync, and development workflow commands

GREEN := \033[0;32m
YELLOW := \033[1;33m
RED := \033[0;31m
BLUE := \033[0;34m
NC := \033[0m # No Color

.PHONY: help simple-status simple-sync simple-critical simple-startup simple-progress simple-learning simple-blocker simple-session-summary simple-daily-sync simple-fix-bug simple-test-priority simple-dynamic-health simple-ai-review simple-ai-refactor simple-ai-test simple-ai-docs simple-ai-optimize simple-ai-security simple-ai-setup simple-ai-debug simple-ai-workflow simple-ai-help discord-setup discord-test discord-status

simple-help: ## Show simple commands help
	@echo "$(GREEN)📋 Simple Commands$(NC)"
	@echo "$(YELLOW)================$(NC)"
	@echo ""
	@echo "$(GREEN)Status & Sync:$(NC)"
	@echo "  simple-status    - Quick project status"
	@echo "  simple-sync      - Team sync"
	@echo "  simple-critical  - Testing priorities"
	@echo ""
	@echo "$(GREEN)Development Workflow:$(NC)"
	@echo "  simple-startup   - Startup checklist"
	@echo "  simple-progress  - Progress tracking"
	@echo "  simple-learning  - Learning notes"
	@echo "  simple-blocker   - Current blockers"
	@echo "  simple-session-summary - Session summary"
	@echo "  simple-daily-sync - Daily sync"
	@echo ""
	@echo "$(GREEN)Trading Systems:$(NC)"
	@echo "  paper-trading-help    - Paper trading shortcuts"
	@echo "  live-trading-help     - Live trading shortcuts"
	@echo ""
	@echo "$(GREEN)AI Development Assistant:$(NC)"
	@echo "  simple-ai-review    - AI code review"
	@echo "  simple-ai-refactor  - AI refactoring"
	@echo "  simple-ai-test      - AI test generation"
	@echo "  simple-ai-docs      - AI documentation"
	@echo "  simple-ai-optimize  - AI performance optimization"
	@echo "  simple-ai-security  - AI security review"
	@echo "  simple-ai-setup     - AI setup assistance"
	@echo "  simple-ai-debug     - AI debugging"
	@echo "  simple-ai-workflow  - AI workflow optimization"
	@echo "  simple-ai-help      - AI assistant help"
	@echo ""

simple-status: ## Quick project status
	@echo "$(GREEN)📊 Trading System Status$(NC)"
	@echo "$(YELLOW)======================$(NC)"
	@echo ""
	@echo "🔌 Port Forwards:"
	@ps aux | grep "kubectl port-forward" | grep -v grep | wc -l | xargs -I {} echo "  Active: {}"
	@echo ""
	@echo "☸️  Kubernetes Pods:"
	@kubectl get pods -n trading-system | grep Running | wc -l | xargs -I {} echo "  Running: {}"
	@echo ""
	@echo "🐳 Registry:"
	@curl -s http://localhost:32000/v2/_catalog > /dev/null 2>&1 && echo "  ✅ Registry active" || echo "  ❌ Registry down"
	@echo ""
	@echo "📋 For detailed status, see: PORT_MAP.md and DEPLOY_MAP.md"

simple-sync: ## Team sync
	@echo "$(GREEN)🔄 Team Sync$(NC)"
	@echo "$(YELLOW)===========$(NC)"
	@echo ""
	@echo "📊 Current Status:"
	@make simple-status
	@echo ""
	@echo "🎯 Recent Changes:"
	@echo "  - Fixed ErrImageNeverPull errors"
	@echo "  - Cleaned up deprecated Makefile references"
	@echo "  - Created deployment management rule"
	@echo ""
	@echo "🚀 Next Priorities:"
	@echo "  - Resolve remaining Makefile conflicts"
	@echo "  - Deploy additional services as needed"
	@echo "  - Monitor system performance"

simple-critical: ## Testing priorities
	@echo "$(GREEN)🚨 Critical Testing Priorities$(NC)"
	@echo "$(YELLOW)============================$(NC)"
	@echo ""
	@echo "1. 🔌 Port Forwarding Health"
	@echo "   - Registry (32000) - $(shell curl -s http://localhost:32000/v2/_catalog > /dev/null 2>&1 && echo "✅ OK" || echo "❌ DOWN")"
	@echo ""
	@echo "2. ☸️  Core Services"
	@echo "   - AI Analysis Service: $(shell kubectl get pods -n trading-system -l app=ai-analysis-service --no-headers 2>/dev/null | grep Running | wc -l | xargs -I {} echo "{} running")"
	@echo "   - Market Data Service: $(shell kubectl get pods -n trading-system -l app=market-data-service --no-headers 2>/dev/null | grep Running | wc -l | xargs -I {} echo "{} running")"
	@echo "   - Unified Dashboards: $(shell kubectl get pods -n trading-system -l app=unified-analytics-dashboard --no-headers 2>/dev/null | grep Running | wc -l | xargs -I {} echo "{} running")"
	@echo ""
	@echo "3. 🐳 Image Registry"
	@echo "   - Total Images: $(shell curl -s http://localhost:32000/v2/_catalog 2>/dev/null | jq '.repositories | length' 2>/dev/null || echo "Unknown")"
	@echo ""
	@echo "4. 📊 System Health"
	@echo "   - Failed Pods: $(shell kubectl get pods -n trading-system | grep -E "(Error|CrashLoopBackOff|ImagePullBackOff)" | wc -l)"
	@echo "   - Pending Pods: $(shell kubectl get pods -n trading-system | grep Pending | wc -l)"

